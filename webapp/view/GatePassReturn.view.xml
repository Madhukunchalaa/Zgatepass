<mvc:View controllerName="zgpms.meilpower.com.controller.GatePassReturn"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page title="Gate Pass Return">
        <content>
            <VBox class="sapUiSmallMargin" alignItems="Center" justifyContent="Center">
                <Panel headerText="Gate pass return" width="500px" class="sapUiMediumMarginTop">
                    <f:SimpleForm editable="true" layout="ResponsiveGridLayout"
                        labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0" columnsL="1" columnsM="1">
                        <f:content>
                            <Label text="Fiscal Year" required="true"/>
                            <Input id="fiscalYear" value="2026" />
                            <Label text="Gate Pass No" required="true"/>
                            <Input id="gatePassNo" placeholder="Enter Gate Pass Number..." />
                            
                            <Label text=""/>
                            <RadioButton text="Receipt of Return material" selected="true" />
                        </f:content>
                    </f:SimpleForm>
                    <HBox justifyContent="SpaceAround" class="sapUiSmallMarginTop">
                        <Button text="Create" type="Emphasized" press="onCreate" width="120px" />
                        <Button text="Display" press="onDisplay" width="120px" />
                    </HBox>
                </Panel>
            </VBox>
        </content>
    </Page>
</mvc:View>
