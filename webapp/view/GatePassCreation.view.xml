<mvc:View
	controllerName="zgpms.meilpower.com.controller.GatePassCreation"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:form="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:unified="sap.ui.unified"
	xmlns:layout="sap.ui.layout"
	height="100%">
	<Page
		id="gatePassCreationPage"
		showHeader="false"
		class="gpmsPage">
		<content>
			<VBox class="gpmsContentWrapper sapUiMediumMargin">

				<!-- ─── SECTION 1 · Gate Pass Details ──────────── -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<core:Icon src="sap-icon://document-text" class="gpmsSectionBarIcon"/>
							<Label text="Gate Pass Request Details" class="gpmsSectionBarLabel"/>
							<ToolbarSpacer/>

							<ObjectStatus text="{gp>/GatePassType}" class="gpmsBadge"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL4 L4 M4 S12" vSpacing="0" hSpacing="1">
						
						<VBox class="sapUiSmallMargin">
							<Label text="Plant" required="true" class="gpmsFieldLabel"/>
							<ComboBox
								id="plantSelect"
								selectedKey="{gp>/Plant}"
								items="{path: 'plants>/results'}"
								selectionChange=".onPlantChange"
								change=".onComboBoxPlantChange"
								placeholder="Select or type Plant code..."
								class="gpmsFieldInput"
								width="100%"
								editable="{gp>/isFieldEditable}">
								<core:ListItem key="{plants>Plant}" text="{plants>Plant} - {plants>PlantName}"/>
							</ComboBox>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Company Code" class="gpmsFieldLabel"/>
							<Input value="{gp>/Cocode}" editable="{gp>/isFieldEditable}" class="gpmsFieldInput" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="GP Date" required="true" class="gpmsFieldLabel"/>
							<DatePicker
								id="gpDate"
								dateValue="{gp>/gpDate}"
								displayFormat="dd-MM-yyyy"
								class="gpmsFieldInput"
								width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="GP Type" required="true" class="gpmsFieldLabel"/>
							<Select
                             id="gpType"
                             selectedKey="{gp>/GatePassType}"
                             enabled="{gp>/isTypeEditable}"
                             class="gpmsFieldInput"
                             width="100%">
    
    <core:Item key="NRGP" text="Non-Returnable Gatepass (NRGP)"/>
    <core:Item key="RGP" text="Returnable Gatepass (RGP)"/>
</Select>
						</VBox>
						<VBox class="sapUiSmallMargin" visible="{= ${gp>/GatePassType} === 'RGP' }">
							<Label text="Due Date" required="true" class="gpmsFieldLabel"/>
							<DatePicker
								dateValue="{gp>/returnableDate}"
								displayFormat="dd-MM-yyyy"
								class="gpmsFieldInput"
								width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Department" required="true" class="gpmsFieldLabel"/>
							<Select
								id="department"
								selectedKey="{gp>/Department}"
								enabled="{gp>/isFieldEditable}"
								class="gpmsFieldInput"
								width="100%">
								<core:Item key="" text="-- Select Department --"/>
								<core:Item key="Boiler Maintenance" text="Boiler Maintenance"/>
								<core:Item key="Turbine Maintenance" text="Turbine Maintenance"/>
								<core:Item key="Balance of Plant" text="Balance of Plant"/>
								<core:Item key="Ash Handling Plant" text="Ash Handling Plant"/>
								<core:Item key="Electrical" text="Electrical"/>
								<core:Item key="C &amp; I" text="C &amp; I"/>
								<core:Item key="Chemistry" text="Chemistry"/>
								<core:Item key="Environment" text="Environment"/>
								<core:Item key="Coal Handling Plant" text="Coal Handling Plant"/>
								<core:Item key="External Coal Handling Plant" text="External Coal Handling Plant"/>
								<core:Item key="Civil maintenance" text="Civil maintenance"/>
								<core:Item key="IT" text="Information &amp; Technology"/>
								<core:Item key="Maintenance Planning" text="Maintenance Planning"/>
								<core:Item key="Main Plant Operation" text="Main Plant Operation"/>
								<core:Item key="Health &amp; Safety" text="Health &amp; Safety"/>
								<core:Item key="Human Resources &amp; Admin" text="Human Resources &amp; Admin"/>
								<core:Item key="Security" text="Security"/>
								<core:Item key="Procurement &amp; Contracts" text="Procurement &amp; Contracts"/>
								<core:Item key="Stores" text="Stores"/>
								<core:Item key="Accounts &amp; Finance" text="Accounts &amp; Finance"/>
								<core:Item key="Engineering &amp; Technical Services" text="Engineering &amp; Technical Services"/>
								<core:Item key="HSE" text="HSE"/>
								<core:Item key="Planning" text="Planning"/>
								<core:Item key="Civil" text="Civil"/>
								<core:Item key="Mechanical" text="Mechanical"/>
								<core:Item key="Commissioning" text="Commissioning"/>
								<core:Item key="P &amp; M" text="P &amp; M"/>
								<core:Item key="Billing &amp; Contracts" text="Billing &amp; Contracts"/>
								<core:Item key="Survey" text="Survey"/>
								<core:Item key="QA &amp; QC" text="QA &amp; QC"/>
								<core:Item key="Maintenance" text="Maintenance"/>
								<core:Item key="Logistics" text="Logistics"/>
								<core:Item key="Process" text="Process"/>
								<core:Item key="SEZ" text="SEZ"/>
								<core:Item key="Production" text="Production"/>
								<core:Item key="Hydro Mechanical" text="Hydro Mechanical"/>
								<core:Item key="E &amp; M (Electro Mechanical )" text="E &amp; M (Electro Mechanical )"/>
								<core:Item key="PMG (Project Monitoring Group)" text="PMG (Project Monitoring Group)"/>
								<core:Item key="Geology" text="Geology"/>
								<core:Item key="Stores T &amp; D" text="Stores T &amp; D"/>
								<core:Item key="Electrical T &amp; D" text="Electrical T &amp; D"/>
								<core:Item key="Fire Dept." text="Fire Dept."/>
								<core:Item key="O&amp;E Dept." text="O&amp;E Dept."/>
							</Select>
						</VBox>
					</layout:Grid>
				</Panel>

				<!-- ─── SECTION 2 · Vendor Information ────────── -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<core:Icon src="sap-icon://home" class="gpmsSectionBarIcon"/>
							<Label text="Vendor Information" class="gpmsSectionBarLabel"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL4 L4 M4 S12" vSpacing="0" hSpacing="1">
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor" required="true" class="gpmsFieldLabel"/>
							<ComboBox
								id="vendorInput"
								selectedKey="{gp>/vendor}"
								placeholder="Search and select vendor..."
								selectionChange=".onVendorSelect"
								class="gpmsFieldInput"
								width="100%"
								items="{path: 'vendors>/results', templateShareable: false}">
								<core:ListItem key="{vendors>Vendor}" text="{vendors>VendorName}" additionalText="{vendors>Vendor}"/>
							</ComboBox>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor Address" class="gpmsFieldLabel"/>
							<Input
								value="{gp>/vendorAddress}"
								placeholder="Enter vendor address"
								class="gpmsFieldInput"
								width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor's GST" class="gpmsFieldLabel"/>
							<Input
								value="{gp>/vendorGST}"
								placeholder="Enter vendor GST"
								class="gpmsFieldInput"
								width="100%"/>
						</VBox>
					</layout:Grid>
				</Panel>

				<!-- ─── SECTION 3 · Attachments ──────────── -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<core:Icon src="sap-icon://attachment" class="gpmsSectionBarIcon"/>
							<Label text="Attachments (Images, PDF, Word)" class="gpmsSectionBarLabel"/>
						</Toolbar>
					</headerToolbar>
					<VBox class="sapUiSmallMargin">
						<HBox alignItems="Center" class="sapUiSmallMarginBottom" wrap="Wrap">
							<unified:FileUploader
								id="photoUploader"
								buttonText="Browse &amp; Upload File(s)"
								class="gpmsFileUploader"
								multiple="true"
								change=".onFileChange"
								tooltip="Upload one or more gate pass attachments (images, PDF, Word documents)"/>
						</HBox>
						
						<!-- List of Uploaded Attachments -->
						<List
							id="attachmentsList"
							noDataText="No attachments uploaded."
							items="{gp>/attachments}"
							class="gpmsAttachmentList">
							<CustomListItem class="gpmsAttachmentListItem">
								<HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
									<HBox alignItems="Center">
										<core:Icon src="sap-icon://attachment" class="gpmsAttachmentIcon sapUiSmallMarginEnd" color="#1A237E"/>
										<VBox>
											<Text text="{gp>name}" class="gpmsAttachmentNameText"/>
											<Text text="{gp>size}" class="gpmsAttachmentSizeText" visible="{= !!${gp>size}}"/>
										</VBox>
									</HBox>
									<Button
										icon="sap-icon://delete"
										type="Transparent"
										press=".onDeleteAttachment"
										class="gpmsDeleteBtn"/>
								</HBox>
							</CustomListItem>
						</List>
					</VBox>
				</Panel>

				<!-- ─── SECTION 4 · Table of Items ────────────── -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<core:Icon src="sap-icon://grid" class="gpmsSectionBarIcon"/>
							<Label text="Table of Items" class="gpmsSectionBarLabel"/>
							<ToolbarSpacer/>
							<Button
								text="Add Row"
								icon="sap-icon://add"
								press=".onAddItem"
								class="gpmsAddBtn"/>
						</Toolbar>
					</headerToolbar>
					<Table
						id="itemsTable"
						items="{path: 'gp>/items', templateShareable: false}"
						noDataText="No items added."
						class="gpmsItemTable">
						<columns>
							<Column width="3rem" hAlign="Center"><Text text="#" class="gpmsHeaderText"/></Column>
							<Column width="12rem"><Text text="Material" class="gpmsHeaderText"/></Column>
							<Column width="15rem"><Text text="Material Description" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="HSN Code" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="Quantity" class="gpmsHeaderText"/></Column>
							<Column width="7rem"><Text text="UOM" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="Rate (Rs.)" class="gpmsHeaderText"/></Column>
							<Column width="10rem"><Text text="Amount" class="gpmsHeaderText"/></Column>
							<Column width="4rem" hAlign="Center"><Text text="" class="gpmsHeaderText"/></Column>
						</columns>
						<items>
							<ColumnListItem vAlign="Middle" class="gpmsItemRow">
								<cells>
									<Text text="{gp>sno}" class="gpmsSnoText"/>

									<Input
										value="{gp>material}"
										showValueHelp="true"
										valueHelpRequest=".onMaterialValueHelp"
										class="gpmsTableInput"
										width="100%"
										placeholder="Material no. or F4..."/>

									<Input
										value="{gp>materialName}"
										showValueHelp="true"
										valueHelpRequest=".onDescriptionEdit"
										class="gpmsTableInput"
										width="100%"
										placeholder="Description (click icon for full edit)..."/>

									<Input
										value="{gp>hsnCode}"
										showSuggestion="true"
										filterSuggests="false"
										suggest=".onHsnCodeInputSuggest"
										suggestionItemSelected=".onHsnCodeInputSuggestionItemSelected"
										class="gpmsTableInput"
										placeholder="HSN code or desc..."/>

									<Input value="{gp>quantity}" textAlign="Right" liveChange=".onQtyRateChange" class="gpmsTableInput"/>

									<Select selectedKey="{gp>uom}" class="gpmsTableInput" width="100%">
										<core:Item key="" text="-- Select --"/>
										<core:Item key="Amps" text="Amps"/>
										<core:Item key="Bag" text="Bag"/>
										<core:Item key="Barrel" text="Barrel"/>
										<core:Item key="Bottle" text="Bottle"/>
										<core:Item key="Box" text="Box"/>
										<core:Item key="Bundle" text="Bundle"/>
										<core:Item key="Can" text="Can"/>
										<core:Item key="Carton" text="Carton"/>
										<core:Item key="Cartridge" text="Cartridge"/>
										<core:Item key="Coil" text="Coil"/>
										<core:Item key="Cubic Feet" text="Cubic Feet"/>
										<core:Item key="Cubic Meter" text="Cubic Meter"/>
										<core:Item key="Cylinder" text="Cylinder"/>
										<core:Item key="Drum" text="Drum"/>
										<core:Item key="Feet" text="Feet"/>
										<core:Item key="Kilogram" text="Kilogram"/>
										<core:Item key="Length" text="Length"/>
										<core:Item key="Litre" text="Litre"/>
										<core:Item key="Load" text="Load"/>
										<core:Item key="Lot" text="Lot"/>
										<core:Item key="Meters" text="Meters"/>
										<core:Item key="Metric Tons" text="Metric Tons"/>
										<core:Item key="Month" text="Month"/>
										<core:Item key="Number" text="Number"/>
										<core:Item key="Pair" text="Pair"/>
										<core:Item key="Roll" text="Roll"/>
										<core:Item key="Set" text="Set"/>
										<core:Item key="Sheet" text="Sheet"/>
										<core:Item key="Square Feet" text="Square Feet"/>
										<core:Item key="Square Meter" text="Square Meter"/>
										<core:Item key="Item" text="Item"/>
										<core:Item key="Pack" text="Pack"/>
										<core:Item key="Days" text="Days"/>
										<core:Item key="Pocket" text="Pocket"/>
										<core:Item key="Ream" text="Ream"/>
										<core:Item key="Tons" text="Tons"/>
										<core:Item key="Unit" text="Unit"/>
									</Select>

									<Input value="{gp>rate}" textAlign="Right" liveChange=".onQtyRateChange" class="gpmsTableInput"/>

									<Text text="{gp>amount}" class="gpmsAmountText" width="100%"/>

									<Button icon="sap-icon://delete" type="Transparent" press=".onRemoveItem" class="gpmsDeleteBtn"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</Panel>

				<!-- ─── SECTION 5 · Remarks & Summary ────────── -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<core:Icon src="sap-icon://notes" class="gpmsSectionBarIcon"/>
							<Label text="Remarks &amp; Summary" class="gpmsSectionBarLabel"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL8 L8 M12 S12" vSpacing="0" hSpacing="1">
						<VBox class="sapUiSmallMargin">
							<Label text="Remarks" class="gpmsFieldLabel"/>
							<TextArea
								value="{gp>/Remarks}"
								placeholder="Enter detailed remarks here (up to 250 characters)..."
								rows="6"
								width="100%"
								maxLength="250"
								showExceededText="true"
								class="gpmsFieldInput gpmsTextAreaBig"/>
						</VBox>
						<VBox class="sapUiSmallMargin" justifyContent="End" alignItems="End">
							<Label text="Final Total (Rs.)" class="gpmsTotalLabel"/>
							<Text text="{gp>/finalTotal}" class="gpmsTotalAmount"/>
						</VBox>
					</layout:Grid>
				</Panel>

			</VBox>
		</content>
		<footer>
			<OverflowToolbar class="gpmsFooterBar">
				<ToolbarSpacer/>
				<Button text="Clear All" icon="sap-icon://clear-all" press=".onClear" class="gpmsClearBtn"/>
				<Button text="{= ${gp>/GatePassReqNo} ? 'Resubmit Request' : 'Submit Gate Pass Request' }" icon="sap-icon://paper-plane" press=".onSubmit" class="gpmsSubmitBtn"/>
			</OverflowToolbar>
		</footer>
	</Page>
</mvc:View>
