<mvc:View
    controllerName="zgpms.meilpower.com.controller.GatePassList"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core">

    <Page title="Gate Pass Requests">
        <subHeader>
            <Bar>
                <contentLeft>
                    <SearchField id="idGatePassSearchField" width="18rem"
                        placeholder="Search by Request No."
                        liveChange=".onSearchFieldLiveChange" />
                </contentLeft>
                <contentMiddle>
                    <Select id="idStatusFilterSelect" width="11rem" change=".onSelectFilterChange">
                        <core:Item key="" text="All Status" />
                        <core:Item key="Approved" text="Approved" />
                        <core:Item key="Pending" text="Pending" />
                        <core:Item key="Store Approval Pending" text="Store Approval Pending" />
                        <core:Item key="Rejected" text="Rejected" />
                        <core:Item key="Closed" text="Closed" />
                        <core:Item key="Cancelled" text="Cancelled" />
                        <core:Item key="Amendment" text="Amendment" />
                    </Select>
                    <Select id="idTypeFilterSelect" width="11rem" change=".onSelectFilterChange">
                        <core:Item key="" text="All Types" />
                        <core:Item key="NRGP" text="NRGP" />
                        <core:Item key="RGP" text="RGP" />
                        <core:Item key="GP with PO" text="GP with PO" />
                    </Select>
                </contentMiddle>
                <contentRight>
                    <Button icon="sap-icon://clear-filter" text="Reset" press=".onResetButtonPress" />
                </contentRight>
            </Bar>
        </subHeader>

        <content>
            <Table id="idItemsGatePassTable"
                items="{gatePassList>/items}"
                noDataText="No gate pass records found."
                growing="true"
                alternateRowColors="true"
                sticky="ColumnHeaders,HeaderToolbar">

                <headerToolbar>
                    <Toolbar>
                        <Title text="Gate Pass Redquest List" level="H3" />
                        <ToolbarSpacer />
                        <Text id="idItemCountText" text="" />
                    </Toolbar>
                </headerToolbar>

                <columns>
                    <Column>
                        <Text text="Request No." />
                    </Column>
                    <Column width="6rem">
                        <Text text="Type" />
                    </Column>
                    <Column width="8rem">
                        <Text text="Status" />
                    </Column>
                    <Column width="6rem">
                        <Text text="Plant" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Vendor Name" />
                    </Column>
                    <Column width="12rem" minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Department" />
                    </Column>
                    <Column width="10rem" minScreenWidth="Tablet" demandPopin="true">
                        <Text text="" />
                    </Column>
                   
                </columns>

                <items>
                    <ColumnListItem
                        type="{= ${user>/IsHodUser} &amp;&amp; ${gatePassList>GatePassType} !== 'GP with PO' ? 'Navigation' : 'Inactive'}"
                        press=".onColumnListItemPress">
                        <cells>
                            <ObjectIdentifier
                                title="{gatePassList>GatePassReqNo}"
                                titleActive="{= ${user>/IsStoreUser} || ${gatePassList>Status} === 'Approved' || ${gatePassList>Status} === 'Amendment' || ${gatePassList>Status} === 'AMENDMENT' }"
                                titlePress=".onObjectIdentifierReqNoTitlePress" />
                            <Text text="{gatePassList>GatePassType}" />
                            <ObjectStatus
                                text="{gatePassList>Status}"
                                state="{= (${gatePassList>Status} === 'Approved' || ${gatePassList>Status} === 'Closed' || ${gatePassList>Status} === 'CLOSED') ? 'Success' : (${gatePassList>Status} === 'Rejected' || ${gatePassList>Status} === 'REJECTED' || ${gatePassList>Status} === 'Cancelled' || ${gatePassList>Status} === 'CANCELLED') ? 'Error' : 'Warning'}" />
                            <Text text="{gatePassList>Plant}" />
                            <Text text="{gatePassList>VendorName}" />
                            <Text text="{gatePassList>Department}" />
                            <Button
                                text="Approve"
                                icon="sap-icon://approvals"
                                type="Accept"
                                class="approveBtn"
                                visible="{= (${gatePassList>Status} === 'Store Approval Pending') &amp;&amp; !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }"
                                press=".onApproveButtonPress" />
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>
        </content>
    </Page>

</mvc:View>
