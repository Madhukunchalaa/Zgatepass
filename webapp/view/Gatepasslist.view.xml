<mvc:View
    controllerName="zgpms.meilpower.com.controller.GatePassList"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core">

    <Page title="Gate Pass Requests">
        <subHeader>
            <Bar>
                <contentLeft>
                    <SearchField id="idGatePassSearchField" width="16rem"
                        placeholder="Search by Request No."
                        liveChange=".onSearchFieldLiveChange" />
                </contentLeft>
                <contentMiddle>
                    <Select id="idStatusFilterSelect" width="11rem" change=".onSelectFilterChange">
                        <core:Item key="" text="All Status" />
                        <core:Item key="Approved" text="Approved" />
                        <core:Item key="Pending" text="Pending" />
                        <core:Item key="Store Approval Pending" text="Store Approval Pending" />
                        <core:Item key="Rejected" text="Rejected" />
                        <core:Item key="Closed" text="Closed" />
                        <core:Item key="Cancelled" text="Cancelled" />
                        <core:Item key="Amendment" text="Amendment" />
                    </Select>
                    <Select id="idTypeFilterSelect" width="10rem" change=".onSelectFilterChange">
                        <core:Item key="" text="All Types" />
                        <core:Item key="NRGP" text="NRGP" />
                        <core:Item key="RGP" text="RGP" />
                        <core:Item key="GP with PO" text="GP with PO" />
                    </Select>

                </contentMiddle>
                <contentRight>
                    <Button icon="sap-icon://clear-filter" text="Reset" press=".onResetButtonPress" />
                </contentRight>
            </Bar>
        </subHeader>

        <content>
            <Table id="idItemsGatePassTable"
                items="{gatePassList>/items}"
                noDataText="No gate pass records found."
                growing="true"
                alternateRowColors="true"
                sticky="ColumnHeaders,HeaderToolbar">

                <headerToolbar>
                    <Toolbar>
                        <Title text="Gate Pass Request List" level="H3" />
                        <ToolbarSpacer />
                        <Text id="idItemCountText" text="" />
                        <DatePicker id="idExcelFromDate" placeholder="From Date" displayFormat="dd-MM-yyyy" width="150px"/>
                        <DatePicker id="idExcelToDate" placeholder="To Date" displayFormat="dd-MM-yyyy" width="150px"/>
                        <Button icon="sap-icon://download" text="Download Excel" press=".onDownloadExcelButtonPress" tooltip="Export to Excel"/>
                    </Toolbar>
                </headerToolbar>

                <columns>
                    <Column>
                        <Text text="Request No." />
                    </Column>
                    <Column width="6rem">
                        <Text text="Type" />
                    </Column>
                    <Column width="8rem">
                        <Text text="Date" />
                    </Column>
                    <Column width="10rem">
                        <Text text="Status" />
                    </Column>
                    <Column width="6rem">
                        <Text text="Plant" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Vendor Name" />
                    </Column>
                    <Column width="12rem" minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Department" />
                    </Column>
                    <Column width="8rem" minScreenWidth="Tablet" demandPopin="true">
                        <Text text="" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        type="{= (${gatePassList>GatePassType} !== 'GP with PO') &amp;&amp; (${user>/IsHodUser} || ${user>/IsStoreUser} || ${gatePassList>Status} === 'Approved' || ${gatePassList>Status} === 'APPROVED' || ${gatePassList>Status} === 'Amendment' || ${gatePassList>Status} === 'AMENDMENT' || ${gatePassList>Status} === 'AM') ? 'Navigation' : 'Inactive'}"
                        press=".onColumnListItemPress">
                        <cells>
                            <ObjectIdentifier
                                title="{gatePassList>GatePassReqNo}"
                                titleActive="{= ${user>/IsStoreUser} || ${gatePassList>Status} === 'Approved' || ${gatePassList>Status} === 'Amendment' || ${gatePassList>Status} === 'AMENDMENT' }"
                                titlePress=".onObjectIdentifierReqNoTitlePress" />
                            <Text text="{gatePassList>GatePassType}" />
                            <Text text="{
                                path: 'gatePassList>GatePassDate',
                                type: 'sap.ui.model.type.Date',
                                formatOptions: {
                                    pattern: 'dd-MM-yyyy'
                                }
                            }" />
                            <ObjectStatus
                                text="{parts: [{path: 'gatePassList>Status'}, {path: 'gatePassList>Approval1'}, {path: 'gatePassList>Approval2'}, {path: 'gatePassList>ApprovalReq'}, {path: 'gatePassList>STORERemarks'}, {path: 'gatePassList>StoreAmmend'}], formatter: '.formatStatus'}"
                                state="{parts: [{path: 'gatePassList>Status'}, {path: 'gatePassList>Approval1'}, {path: 'gatePassList>Approval2'}, {path: 'gatePassList>ApprovalReq'}, {path: 'gatePassList>STORERemarks'}, {path: 'gatePassList>StoreAmmend'}], formatter: '.formatStatusState'}" />
                            <Text text="{gatePassList>Plant}" />
                            <Text text="{gatePassList>VendorName}" />
                            <Text text="{gatePassList>Department}" />
                            <Button
                                text="Approve"
                                icon="sap-icon://approvals"
                                type="Accept"
                                class="approveBtn"
                                visible="{parts: [{path: 'gatePassList>Status'}, {path: 'gatePassList>Approval1'}, {path: 'gatePassList>Approval2'}, {path: 'gatePassList>ApprovalReq'}, {path: 'gatePassList>STORERemarks'}, {path: 'gatePassList>StoreAmmend'}], formatter: '.showApproveBtn'}"
                                press=".onApproveButtonPress" />
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>
        </content>
    </Page>
</mvc:View>
