<mvc:View controllerName="zgpms.meilpower.com.controller.GatePassRequestCreation"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns="sap.m">

    <Page title="Gate Pass Request">
        <content>
            <!-- HEADER SECTION (Matches SAP GUI Layout) -->
            <f:Form editable="true">
                <f:title>
                    <core:Title text="Gate pass request" />
                </f:title>
                <f:layout>
                    <f:ResponsiveGridLayout
                        labelSpanXL="4"
                        labelSpanL="4"
                        labelSpanM="4"
                        labelSpanS="12"
                        adjustLabelSpan="false"
                        emptySpanXL="0"
                        emptySpanL="0"
                        emptySpanM="0"
                        emptySpanS="0"
                        columnsXL="3"
                        columnsL="3"
                        columnsM="2"
                        singleContainerFullSize="false" />
                </f:layout>
                <f:formContainers>
                    <!-- Column 1 -->
                    <f:FormContainer>
                        <f:formElements>
                            <f:FormElement label="Gate Pass Req No">
                                <f:fields>
                                    <Input value="{localModel>/GatePassReqNo}" editable="false" />
                                </f:fields>
                            </f:FormElement>
                             <f:FormElement label="Company Code">
                                 <f:fields>
                                     <Input value="{localModel>/CompanyCode}" editable="true" />
                                 </f:fields>
                             </f:FormElement>
                             <f:FormElement label="Plant">
                                 <f:fields>
                                     <Input value="{localModel>/Plant}" editable="false" />
                                 </f:fields>
                             </f:FormElement>
                             <f:FormElement label="Supplier">
                                 <f:fields>
                                     <ComboBox selectedKey="{localModel>/Vendor}" selectionChange="onVendorChange" items="{vendorModel>/vendors}" showSecondaryValues="true" filterSecondaryValues="true">
                                         <core:Item key="{vendorModel>Vendor}" text="{vendorModel>Vendor} - {vendorModel>Name}" />
                                     </ComboBox>
                                 </f:fields>
                             </f:FormElement>
                            <f:FormElement label="Vendor Name">
                                <f:fields>
                                    <Input value="{localModel>/VendorName}" editable="false" />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement label="Street and House No">
                                <f:fields>
                                    <Input value="{localModel>/Street}" />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement label="City">
                                <f:fields>
                                    <Input value="{localModel>/City}" editable="false" />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement label="Postal Code">
                                <f:fields>
                                    <Input value="{localModel>/ZipCode}" editable="false" />
                                </f:fields>
                            </f:FormElement>
                        </f:formElements>
                    </f:FormContainer>

                    <!-- Column 2 -->
                    <f:FormContainer>
                        <f:formElements>
                            <f:FormElement label="No of Packages">
                                <f:fields>
                                    <Input value="{localModel>/NoOfPackages}" />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement label="Exp. Return date" visible="{= ${localModel>/GatePassType} === 'RGP'}">
                                <f:fields>
                                    <DatePicker value="{localModel>/ReturnableDate}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" editable="true" />
                                </f:fields>
                            </f:FormElement>
                             <f:FormElement label="Category">
                                 <f:fields>
                                     <Input value="{localModel>/InternalExternalType}" editable="false" />
                                 </f:fields>
                             </f:FormElement>
                             <f:FormElement label="Gatepass Type">
                                 <f:fields>
                                     <Input value="{localModel>/GatePassType}" editable="false" />
                                 </f:fields>
                             </f:FormElement>
</f:formElements>
                    </f:FormContainer>

                    <!-- Column 3 -->
                    <f:FormContainer>
                        <f:formElements>
                            <f:FormElement label="Department">
                                <f:fields>
                                    <Select selectedKey="{localModel>/Department}">
                                        <core:Item key="" text=""/>
                                        <core:Item key="Boiler Maintenance" text="Boiler Maintenance"/>
                                        <core:Item key="Turbine Maintenance" text="Turbine Maintenance"/>
                                        <core:Item key="Electrical" text="Electrical"/>
                                        <core:Item key="Mechanical" text="Mechanical"/>
                                        <core:Item key="Civil" text="Civil"/>
                                        <core:Item key="Stores" text="Stores"/>
                                        <core:Item key="IT" text="Information &amp; Technology"/>
                                        <core:Item key="HR" text="Human Resources &amp; Admin"/>
                                        <core:Item key="Finance" text="Accounts &amp; Finance"/>
                                        <core:Item key="Security" text="Security"/>
                                        <core:Item key="HSE" text="HSE"/>
                                    </Select>
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement label="Requester Emp ID">
                                <f:fields>
                                    <Input value="{localModel>/ReqEmpID}" showValueHelp="true" />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement label="HOD Emp ID">
                                <f:fields>
                                    <Input value="{localModel>/HODEmpID}" showValueHelp="true" />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement label="Store HOD Emp ID">
                                <f:fields>
                                    <Input value="{localModel>/StoreHODEmpID}" />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement label="Finance HOD Emp ID">
                                <f:fields>
                                    <Input value="{localModel>/FinanceHODId}" />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement label="Plant HOD Emp ID">
                                <f:fields>
                                    <Input value="{localModel>/PlantHODId}" />
                                </f:fields>
                            </f:FormElement>
                        </f:formElements>
                    </f:FormContainer>
                </f:formContainers>
            </f:Form>

            <!-- ITEMS TABLE -->
            <Table id="idGateReqItemNavTable" items="{localModel>/GateReqItemNav}" alternateRowColors="true" sticky="HeaderToolbar,InfoToolbar,ColumnHeaders">
                <headerToolbar>
                    <Toolbar>
                        <Title text="Item Details" />
                        <ToolbarSpacer />
                        <Button text="Add Item" icon="sap-icon://add" press="onAddItemButtonPress" />
                    </Toolbar>
                </headerToolbar>
                <columns>
            
                    <Column width="60px"><Text text="Item" /></Column>
                    <Column width="120px"><Text text="Material" /></Column>
                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="Material Description" /></Column>
                    <Column width="60px"><Text text="UOM" /></Column>
                    <Column width="100px"><Text text="Sent Quantity" /></Column>
                    <Column width="100px"><Text text="Requested Qty" /></Column>
                    <Column width="100px"><Text text="Unit Price" /></Column>
                    <Column width="100px"><Text text="Total Value" /></Column>
                
                    <Column width="40px"></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                
                            <Input value="{localModel>ItemNo}" editable="false" width="70px" />
                            <Input value="{localModel>Material}" showValueHelp="true" valueHelpRequest="onMaterialInputValueHelpRequest" />
                            <Input value="{localModel>Description}" />
                            <Input value="{localModel>UOM}" maxLength="3" />
                            <Input value="{localModel>SentQuantity}" type="Number" liveChange="onSentQtyChange" />
                            <Input value="{localModel>RequestedQuantity}" type="Number" editable="false" />
                            <Input value="{localModel>ItemNetPrice}" type="Number" liveChange="onSentQtyChange" />
                            <Text text="{localModel>Totalvalue}" />
                           
                            <Button icon="sap-icon://delete" type="Transparent" press="onButtonDeletePress" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

            <!-- FOOTER SECTION (gate) -->
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" title="gate" labelSpanL="3" labelSpanM="3" columnsL="1" columnsM="1">
                <f:content>
                    <Label text="Remarks" />
                    <Input value="{localModel>/Remarks}" />
                    <Label text="Mode of Dispatch" />
                    <Input value="{localModel>/ModeOfDispatch}" />
                    <Label text="Vehicle No" />
                    <Input value="{localModel>/VehicleNo}" />
                </f:content>
            </f:SimpleForm>
        </content>

        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button text="Save" type="Emphasized" press="onSubmitPress" width="100px" />
                <Button text="Reset" type="Transparent" press="onClearFormPress" width="100px" />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
