<mvc:View
	controllerName="zgpms.meilpower.com.controller.AshGatePassDetail"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:form="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	height="100%">
	<Page
		id="ashGatePassDetailPage"
		title="Ash Gate pass Detail"
		showNavButton="true"
		navButtonPress=".onNavBack"
		class="gpmsPage">
		<content>
			<VBox class="gpmsContentWrapper sapUiMediumMargin">
				
				<MessageStrip text="Gate Pass Details Loaded" type="Success" showIcon="true" class="sapUiSmallMarginBottom"/>

				<!-- Main Form -->
				<Panel class="gpmsSection" expandable="false">
					<layout:Grid defaultSpan="XL6 L6 M6 S12" vSpacing="0" hSpacing="1">
						<VBox class="sapUiSmallMargin">
							<Label text="GP Date" class="gpmsFieldLabel"/>
							<Input value="{path: 'ash>/GPDate', formatter: '.formatDate'}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Gate Pass No" class="gpmsFieldLabel"/>
							<Input value="{ash>/GatePassNo}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						
						<VBox class="sapUiSmallMargin">
							<Label text="Sales Document" class="gpmsFieldLabel"/>
							<Input value="{ash>/SalesDocument}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Customer (Sold-to Party)" class="gpmsFieldLabel"/>
							<Input value="{ash>/SoldToParty}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						
						<VBox class="sapUiSmallMargin">
							<Label text="Customer Name" class="gpmsFieldLabel"/>
							<Input value="{ash>/CustomerName}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Customer's GST" class="gpmsFieldLabel"/>
							<Input value="{ash>/CustomerGst}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="City" class="gpmsFieldLabel"/>
							<Input value="{ash>/City}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Zip Code" class="gpmsFieldLabel"/>
							<Input value="{ash>/ZipCode}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
					</layout:Grid>
				</Panel>

				<!-- Table of Items -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<Label text="Table of Items" class="gpmsSectionBarLabel"/>
						</Toolbar>
					</headerToolbar>
					<Table items="{ash>/ASHItmNav}" noDataText="No items found." class="gpmsItemTable">
						<columns>
							<Column width="3rem"><Text text="Item" class="gpmsHeaderText"/></Column>
							<Column width="10rem"><Text text="Material Code" class="gpmsHeaderText"/></Column>
							<Column><Text text="Material Description" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="HSN Code" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="Qty" class="gpmsHeaderText"/></Column>
							<Column width="6rem"><Text text="UOM" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="Rate" class="gpmsHeaderText"/></Column>
							<Column width="9rem"><Text text="Total Value" class="gpmsHeaderText"/></Column>
						</columns>
						<items>
							<ColumnListItem class="gpmsItemRow">
								<cells>
									<Text text="{ash>ItemNo}" class="gpmsTableText"/>
									<Text text="{ash>Material}" class="gpmsTableText"/>
									<Text text="{ash>MaterialDescription}" class="gpmsTableText"/>
									<Text text="{ash>HSNCode}" class="gpmsTableText"/>
									<Text text="{ash>RequestedQuantity}" class="gpmsTableText"/>
									<Text text="{ash>UOM}" class="gpmsTableText"/>
									<Text text="{ash>ItemNetPrice}" class="gpmsTableText"/>
									<Text text="{ash>Totalvalue}" class="gpmsTableText"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</Panel>

				<!-- Remarks & Summary -->
				<Panel class="gpmsSection" expandable="false">
					<layout:Grid defaultSpan="XL6 L6 M6 S12" vSpacing="0" hSpacing="1">
						<VBox class="sapUiSmallMargin">
							<Label text="Remarks" class="gpmsFieldLabel"/>
							<Input value="{ash>/Remarks}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Final Total Rs." class="gpmsFieldLabel"/>
							<Input value="{ash>/finalTotal}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="Vehicle No." class="gpmsFieldLabel"/>
							<Input value="{ash>/VehicleNo}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Mode of Dispatch" class="gpmsFieldLabel"/>
							<Input value="{ash>/ModeOfDispatch}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="Transporter Name" class="gpmsFieldLabel"/>
							<Input value="{ash>/TransporterName}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Transporter GST" class="gpmsFieldLabel"/>
							<Input value="{ash>/TransporterGst}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="DC Notes" class="gpmsFieldLabel"/>
							<Input value="{ash>/DCNotes}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
					</layout:Grid>
				</Panel>
			</VBox>
		</content>
		<footer>
			<OverflowToolbar class="gpmsFooterBar">
				<ToolbarSpacer/>
				<Button text="Back" type="Reject" press=".onNavBack"/>
				<Button text="Print PDF" type="Emphasized" icon="sap-icon://print" press=".onPrint"/>
			</OverflowToolbar>
		</footer>
	</Page>
</mvc:View>
