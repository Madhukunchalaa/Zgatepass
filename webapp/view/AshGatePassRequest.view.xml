<mvc:View
	controllerName="zgpms.meilpower.com.controller.AshGatePassRequest"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	height="100%">
	<Page
		id="ashGatePassRequestPage"
		title="Ash Gate Pass Request"
		showNavButton="true"
		navButtonPress=".onNavBack"
		class="gpmsPage">
		<content>
			<VBox class="gpmsContentWrapper sapUiMediumMargin">

				<!-- Main Form -->
				<Panel class="gpmsSection" expandable="false">
					<layout:Grid defaultSpan="XL6 L6 M6 S12" vSpacing="0" hSpacing="1">
						<VBox class="sapUiSmallMargin">
							<Label text="GP Date" class="gpmsFieldLabel"/>
							<DatePicker
								dateValue="{ashReq>/GPDate}"
								displayFormat="dd-MM-yyyy"
								class="gpmsFieldInput"
								width="100%"
								editable="false"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Sales Document" required="true" class="gpmsFieldLabel"/>
							<Input
								id="idAshReqSalesDocument"
								value="{ashReq>/SalesDocument}"
								placeholder="Enter/Select Sales Document"
								class="gpmsFieldInput"
								showValueHelp="true"
								valueHelpRequest=".onSalesDocValueHelp"
								change=".onSalesDocChange"
								width="100%"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="GP Type" class="gpmsFieldLabel"/>
							<Input value="Non-Returnable Gatepass (NRGP)" editable="false" class="gpmsFieldInput" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Customer (Sold-to Party)" class="gpmsFieldLabel"/>
							<Input value="{ashReq>/SoldToParty}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="Customer Name" class="gpmsFieldLabel"/>
							<Input value="{ashReq>/CustomerName}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Customer's GST" class="gpmsFieldLabel"/>
							<Input value="{ashReq>/CustomerGst}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="City" class="gpmsFieldLabel"/>
							<Input value="{ashReq>/City}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Zip Code" class="gpmsFieldLabel"/>
							<Input value="{ashReq>/ZipCode}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
					</layout:Grid>
				</Panel>

				<!-- Table of Items -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<Label text="Table of Items" class="gpmsSectionBarLabel"/>
						</Toolbar>
					</headerToolbar>
					<Table items="{ashReq>/ASHItmNav}" noDataText="No items loaded from Sales Document." class="gpmsItemTable">
						<columns>
							<Column width="3rem"><Text text="Item" class="gpmsHeaderText"/></Column>
							<Column width="10rem"><Text text="Material Code" class="gpmsHeaderText"/></Column>
							<Column><Text text="Material Description" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="HSN Code" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="Qty *" class="gpmsHeaderText"/></Column>
							<Column width="6rem"><Text text="UOM" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="Rate *" class="gpmsHeaderText"/></Column>
							<Column width="9rem"><Text text="Total Value" class="gpmsHeaderText"/></Column>
						</columns>
						<items>
							<ColumnListItem class="gpmsItemRow">
								<cells>
									<Text text="{ashReq>ItemNo}" class="gpmsTableText"/>
									<Text text="{ashReq>Material}" class="gpmsTableText"/>
									<Text text="{ashReq>MaterialDescription}" class="gpmsTableText"/>
									<Input value="{ashReq>HSNCode}" class="gpmsTableInput"/>
									<Input value="{ashReq>RequestedQuantity}" type="Text" liveChange=".calculateTotal" class="gpmsTableInput"/>
									<Text text="{ashReq>UOM}" class="gpmsTableText"/>
									<Input value="{ashReq>ItemNetPrice}" type="Text" liveChange=".calculateTotal" class="gpmsTableInput"/>
									<Text text="{ashReq>Totalvalue}" class="gpmsTableText"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</Panel>

				<!-- Remarks & Total -->
				<Panel class="gpmsSection sapUiSmallMarginBottom" expandable="false">
					<layout:Grid defaultSpan="XL6 L6 M6 S12" vSpacing="0" hSpacing="1">
						<VBox class="sapUiSmallMargin">
							<Label text="Remarks" class="gpmsFieldLabel"/>
							<TextArea value="{ashReq>/Remarks}" placeholder="Enter remarks" rows="3" width="100%" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Final Total Rs." class="gpmsFieldLabel"/>
							<Input value="{ashReq>/finalTotal}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
					</layout:Grid>
				</Panel>

				<!-- Logistics & Transport -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar height="2.5rem">
							<core:Icon src="sap-icon://shipping-status" class="sapUiSmallMarginEnd"/>
							<Title text="LOGISTICS &amp; TRANSPORT" level="H4"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL4 L4 M6 S12" vSpacing="0" hSpacing="1">
						<VBox class="sapUiSmallMargin">
							<Label text="Vehicle No." required="true" class="gpmsFieldLabel"/>
							<Input value="{ashReq>/VehicleNo}" placeholder="Enter Vehicle No" class="gpmsFieldInput" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Mode of Dispatch" class="gpmsFieldLabel"/>
							<Select selectedKey="{ashReq>/ModeOfDispatch}" class="gpmsFieldInput" width="100%">
								<core:Item key="ROAD" text="ROAD" />
								<core:Item key="RAIL" text="RAIL" />
								<core:Item key="AIR" text="AIR" />
							</Select>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Transporter Name" class="gpmsFieldLabel"/>
							<Input value="{ashReq>/TransporterName}" placeholder="Enter Transporter Name" class="gpmsFieldInput" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Transporter GST" class="gpmsFieldLabel"/>
							<Input value="{ashReq>/TransporterGst}" placeholder="Enter Transporter GST" class="gpmsFieldInput" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="DC Number" class="gpmsFieldLabel"/>
							<Input value="{ashReq>/DCNumber}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="DC Date" class="gpmsFieldLabel"/>
							<DatePicker
								value="{ashReq>/DCDate}"
								valueFormat="yyyyMMdd"
								displayFormat="dd-MM-yyyy"
								class="gpmsFieldInput"
								width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="WB Ticket No" class="gpmsFieldLabel"/>
							<Input value="{ashReq>/WBTicketNo}" editable="false" class="gpmsFieldInput gpmsFieldInputReadonly" width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<layoutData>
								<layout:GridData span="XL8 L8 M12 S12"/>
							</layoutData>
							<Label text="DC Notes" class="gpmsFieldLabel"/>
							<TextArea value="{ashReq>/DCNotes}" placeholder="Enter DC Notes" rows="2" width="100%" class="gpmsFieldInput"/>
						</VBox>
					</layout:Grid>
				</Panel>
			</VBox>
		</content>
		<footer>
			<OverflowToolbar class="gpmsFooterBar">
				<ToolbarSpacer/>
				<Button text="Back" type="Reject" press=".onNavBack"/>
				<Button text="Submit Request" type="Emphasized" press=".onSubmit" class="gpmsSubmitBtn sapUiSmallMarginBegin"/>
			</OverflowToolbar>
		</footer>
	</Page>
</mvc:View>
