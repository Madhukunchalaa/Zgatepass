<mvc:View
	controllerName="zgpms.meilpower.com.controller.App"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:tnt="sap.tnt"
	height="100%"
	displayBlock="true">
	<tnt:ToolPage id="toolPage">
		<tnt:header>
			<tnt:ToolHeader class="gpmsShellBar">
				<Button
					icon="sap-icon://menu2"
					type="Transparent"
					press=".onSideNavButtonPress">
					<layoutData>
						<OverflowToolbarLayoutData priority="NeverOverflow" />
					</layoutData>
				</Button>
				<Image src="assets/img/logo.png" height="40px" class="sapUiTinyMarginBegin"/>
				<ToolbarSpacer width="10px"/>
				<Title text="Gate Pass Management System" level="H1" class="sapUiTinyMarginBegin gpmsShellBarTitle"/>
				<ToolbarSpacer />
				<Avatar initials="AD" displaySize="XS" class="sapUiTinyMarginEnd"/>
			</tnt:ToolHeader>
		</tnt:header>
		<tnt:sideContent>
			<tnt:SideNavigation selectedKey="home" itemSelect=".onItemSelect" class="gpmsSideNav">
				<tnt:NavigationList>
					<tnt:NavigationListItem text="Dashboard" icon="sap-icon://home" key="home" />
					<tnt:NavigationListItem text="NRGP Request" icon="sap-icon://add-document" key="nrgp" />
					<tnt:NavigationListItem text="RGP Request" icon="sap-icon://shipping-status" key="rgp" />
					<tnt:NavigationListItem text="Out Gate Pass" icon="sap-icon://open-folder" key="OutGatePass" />
					<tnt:NavigationListItem text="Inward Gate Pass" icon="sap-icon://down-back" key="InwardGatePass" />
					<tnt:NavigationListItem text="Reports" icon="sap-icon://business-objects-experience" key="analytics" />
					<tnt:NavigationListItem text="Gate Pass List" icon="sap-icon://list" key="GatePassList" />
				</tnt:NavigationList>
				<tnt:fixedItem>
					<tnt:NavigationList>
						<tnt:NavigationListItem text="Settings" icon="sap-icon://settings" key="settings" />
					</tnt:NavigationList>
				</tnt:fixedItem>
			</tnt:SideNavigation>
		</tnt:sideContent>
		<tnt:mainContents>
			<App id="idMainApp"/>
		</tnt:mainContents>
	</tnt:ToolPage>
</mvc:View>
