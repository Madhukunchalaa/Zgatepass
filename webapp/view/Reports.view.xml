<mvc:View
	controllerName="zgpms.meilpower.com.controller.Reports"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	height="100%">

	<Page id="idReportsPage"
		title="GPMS Reports Download"
		class="gpmsPage"
		showNavButton="true"
		navButtonPress=".onPageReportsNavButtonPress">

		<content>
			<VBox class="gpmsContentWrapper sapUiMediumMargin">

				<!-- Date Range Filter Panel -->
				<Panel expandable="false" class="gpmsPanel sapUiSmallMarginBottom">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://filter" class="sapUiSmallMarginEnd"/>
							<Title text="Date Range Filter" level="H3"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL3 L3 M6 S12" vSpacing="0">
						<VBox class="sapUiSmallMargin">
							<Label text="From Date" class="gpmsFieldLabel"/>
							<DatePicker id="idReportFromDatePicker"
								placeholder="Select From Date"
								displayFormat="dd-MM-yyyy"
								class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="To Date" class="gpmsFieldLabel"/>
							<DatePicker id="idReportToDatePicker"
								placeholder="Select To Date"
								displayFormat="dd-MM-yyyy"
								class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin" justifyContent="End">
							<Button
								text="Generate All Reports"
								icon="sap-icon://excel-attachment"
								type="Emphasized"
								press=".onGenerateAllReportsButtonPress"
								class="sapUiSmallMarginTop"/>
						</VBox>
					</layout:Grid>
				</Panel>

				<!-- Reports Index Table -->
				<Table id="idReportsTable"
					items="{reportIndex>/reports}"
					noDataText="No reports available."
					alternateRowColors="true"
					sticky="ColumnHeaders,HeaderToolbar">

					<headerToolbar>
						<OverflowToolbar class="gpmsSectionBar">
							<core:Icon src="sap-icon://excel-attachment" class="sapUiSmallMarginEnd"/>
							<Title text="GPMS Report Index — 16 Sheets" level="H3"/>
							<ToolbarSpacer/>
							<Text text="All available reports are generated in one Excel workbook"/>
						</OverflowToolbar>
					</headerToolbar>

					<columns>
						<Column width="3rem" hAlign="Center">
							<Text text="S.No" class="gpmsHeaderText"/>
						</Column>
						<Column width="14rem">
							<Text text="Report Name" class="gpmsHeaderText"/>
						</Column>
						<Column width="18rem" minScreenWidth="Tablet" demandPopin="true">
							<Text text="Description" class="gpmsHeaderText"/>
						</Column>
						<Column width="7rem" hAlign="Center">
							<Text text="Status" class="gpmsHeaderText"/>
						</Column>
						<Column minScreenWidth="Tablet" demandPopin="true">
							<Text text="How to Download" class="gpmsHeaderText"/>
						</Column>
					</columns>

					<items>
						<ColumnListItem vAlign="Middle" class="gpmsItemRow">
							<cells>
								<Text text="{reportIndex>sno}" class="gpmsTableText"/>
								<Text text="{reportIndex>name}" class="gpmsTableText"/>
								<Text text="{reportIndex>desc}" class="gpmsTableText"/>
								<ObjectStatus
									text="{reportIndex>status}"
									state="{= ${reportIndex>status} === 'Available' ? 'Success' : 'Warning'}"
									icon="{= ${reportIndex>status} === 'Available' ? 'sap-icon://sys-enter-2' : 'sap-icon://pending'}"/>
								<Text text="{reportIndex>howto}" class="gpmsTableText"/>
							</cells>
						</ColumnListItem>
					</items>
				</Table>

				<!-- Info Message Strip -->
				<MessageStrip
					text="Click 'Generate All Reports' to download a single Excel workbook with Index + 16 report sheets. Set From/To dates to filter by date range. Reports marked 'Pending' will have placeholder sheets."
					type="Information"
					showIcon="true"
					showCloseButton="false"
					class="sapUiSmallMarginTop"/>

			</VBox>
		</content>
	</Page>
</mvc:View>
