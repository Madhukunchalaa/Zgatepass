<mvc:View
    controllerName="zgpms.meilpower.com.controller.NRGPList"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core">

    <Page title="Out Gate Pass List">
        <subHeader>
            <Bar>
                <contentLeft>
                    <SearchField id="idNRGPSearchField" width="18rem"
                        placeholder="Search by GP No. or Req No."
                        liveChange=".onSearchFieldLiveChange" />
                </contentLeft>
                <contentMiddle>
                    <Select id="idNRGPTypeSelect" width="10rem" change=".onSelectFilterChange">
                        <core:Item key="" text="All Types" />
                        <core:Item key="NRGP" text="NRGP" />
                        <core:Item key="RGP" text="RGP" />
                        <core:Item key="PO" text="PO" />
                    </Select>
                    <Select id="idNRGPStatusSelect" width="14rem" change=".onSelectFilterChange">
                        <core:Item key="" text="All Status" />
                        <core:Item key="OPEN" text="OPEN" />
                        <core:Item key="AWAITING FOR VENDOR ACKNOWLEDGEMENT" text="Awaiting Acknowledgement" />
                        <core:Item key="AWAITING_FOR_RETURN" text="Awaiting for Return" />
                        <core:Item key="CLOSED" text="CLOSED" />
                        <core:Item key="CANCELLED" text="CANCELLED" />
                        <core:Item key="Pending" text="Pending" />
                        <core:Item key="Approved" text="Approved" />
                        <core:Item key="Rejected" text="Rejected" />
                    </Select>
                </contentMiddle>
                <contentRight>
                    <DatePicker id="idNRGPFromDatePicker" displayFormat="dd-MM-yyyy" valueFormat="yyyy-MM-dd" width="9rem" change=".onDatePickerChange" placeholder="From Date"/>
                    <DatePicker id="idNRGPToDatePicker" displayFormat="dd-MM-yyyy" valueFormat="yyyy-MM-dd" width="9rem" change=".onDatePickerChange" placeholder="To Date"/>
                    <Button icon="sap-icon://clear-filter" text="Reset" press=".onResetButtonPress" />
                </contentRight>
            </Bar>
        </subHeader>

        <content>
            <Table id="idItemsNRGPTable"
                items="{nrgpList>/items}"
                noDataText="No gate pass records found."
                growing="true"
                alternateRowColors="true"
                sticky="ColumnHeaders,HeaderToolbar">

                <headerToolbar>
                    <Toolbar>
                        <Title text="Out Gate Pass List" level="H3" />
                        <ToolbarSpacer />
                        <Text id="idNRGPCountText" text="" />
                        <Button id="idNRGPDownloadExcelBtn" icon="sap-icon://download" text="Download Excel" press=".onDownloadExcel" tooltip="Export to Excel" class="sapUiTinyMarginEnd"/>
                        <Button id="idNRGPCopyListBtn" icon="sap-icon://copy" text="Copy" press=".onCopyList" tooltip="Copy list to clipboard" class="sapUiTinyMarginEnd"/>
                        <Button id="idNRGPPrintListBtn" icon="sap-icon://print" text="Print List" press=".onPrintList" tooltip="Print gate pass list"/>
                    </Toolbar>
                </headerToolbar>

                <columns>
                    <Column width="9rem">
                        <Text text="GP Date" wrapping="false"/>
                    </Column>
                    <Column width="11rem">
                        <Text text="GP No" wrapping="false"/>
                    </Column>
                    <Column width="9rem">
                        <Text text="GP Req No" wrapping="false"/>
                    </Column>
                    <Column width="5rem">
                        <Text text="GP Type" wrapping="false"/>
                    </Column>
                    <Column width="8rem" minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Due Date" wrapping="false"/>
                    </Column>
                    <Column width="8rem" minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Ret Date" wrapping="false"/>
                    </Column>
                    <Column width="10rem" minScreenWidth="Desktop" demandPopin="true">
                        <Text text="Vendor" wrapping="false"/>
                    </Column>
                    <Column width="8rem" minScreenWidth="Desktop" demandPopin="true">
                        <Text text="Req Dept" wrapping="false"/>
                    </Column>
                    <Column minScreenWidth="Desktop" demandPopin="true">
                        <Text text="Desc" />
                    </Column>
                    <Column width="10rem">
                        <Text text="Status" wrapping="false"/>
                    </Column>
                    <Column width="7rem" hAlign="Center">
                        <Text text="Action" wrapping="false"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem type="Inactive" press=".onColumnListItemPress">
                        <cells>
                            <Text text="{nrgpList>GatePassDate}" wrapping="false"/>
                            <Text text="{nrgpList>GatePassNo}" wrapping="false" class="sapMObjectIdentifierTitle"/>
                            <Text text="{nrgpList>GatePassreqNo}" wrapping="false"/>
                            <ObjectStatus
                                text="{nrgpList>GatePassType}"
                                state="{= ${nrgpList>GatePassType} === 'RGP' ? 'Information' : ${nrgpList>GatePassType} === 'PO' ? 'Success' : 'None'}"/>
                            <Text text="{nrgpList>DueDate}" wrapping="false"/>
                            <Text text="{nrgpList>ReturnDate}" wrapping="false"/>
                            <Text text="{nrgpList>VendorName}" wrapping="true"/>
                            <Text text="{nrgpList>Department}" wrapping="false"/>
                            <Text text="{nrgpList>CommonDesc}" />
                            <ObjectStatus
                                text="{= ${nrgpList>GPStatusText} ? ${nrgpList>GPStatusText} : 'Not Set'}"
                                state="{nrgpList>StatusState}"/>
                            <HBox justifyContent="Center">
                                <Button icon="sap-icon://edit" type="Emphasized" press=".onEditRow"/>
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>
        </content>
    </Page>

</mvc:View>
