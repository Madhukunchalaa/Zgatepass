<mvc:View
	controllerName="zgpms.meilpower.com.controller.AshGatePassList"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	height="100%">
	<Page
		title="Ash Gate Pass List"
		showNavButton="true"
		navButtonPress=".onNavBack"
		class="gpmsPage">
		<content>
			<VBox class="sapUiSmallMargin">
				<Table
					id="ashListTable"
					items="{path: '/AshHdrSet', filters: [{path: 'GatePassType', operator: 'EQ', value1: 'NRGP'}]}"
					noDataText="No Ash Gate Passes found"
					class="gpmsTable"
					alternateRowColors="true">
					<headerToolbar>
						<OverflowToolbar>
							<Title text="Ash Gate Passes" level="H2"/>
							<ToolbarSpacer/>
							<SearchField width="300px" search=".onSearch" placeholder="Search Gate Pass No..." class="gpmsFieldInput"/>
							<DatePicker id="idExcelFromDate" placeholder="From Date" displayFormat="dd-MM-yyyy" width="150px" change=".onDateFilterChange"/>
							<DatePicker id="idExcelToDate" placeholder="To Date" displayFormat="dd-MM-yyyy" width="150px" change=".onDateFilterChange"/>
							<Button icon="sap-icon://download" text="Download Excel" press=".onDownloadExcel" tooltip="Export to Excel"/>
							<Button id="idAshCopyListBtn" icon="sap-icon://copy" text="Copy" press=".onCopyList" tooltip="Copy list to clipboard"/>
							<Button id="idAshPrintListBtn" icon="sap-icon://print" text="Print List" press=".onPrintList" tooltip="Print list"/>
						</OverflowToolbar>
					</headerToolbar>
					<columns>
						<Column><Text text="Gate Pass No" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="Sales Document" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="Customer Name" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="Vehicle No" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="GP Date" class="gpmsTableHeaderText"/></Column>
						<Column hAlign="Center" width="4rem"><Text text="Action" class="gpmsTableHeaderText"/></Column>
					</columns>
					<items>
						<ColumnListItem type="Navigation" press=".onRowPress" class="gpmsTableRow">
							<cells>
								<Text text="{GatePassNo}" class="gpmsTableText"/>
								<Text text="{SalesDocument}" class="gpmsTableText"/>
								<Text text="{CustomerName}" class="gpmsTableText"/>
								<Text text="{VehicleNo}" class="gpmsTableText"/>
								<Text text="{path: 'GPDate', formatter: '.formatDate'}" class="gpmsTableText"/>
								<Button icon="sap-icon://navigation-right-arrow" type="Transparent" press=".onRowPress" tooltip="Open Details"/>
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</VBox>
		</content>
	</Page>
</mvc:View>
