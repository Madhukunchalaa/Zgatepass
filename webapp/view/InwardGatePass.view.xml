<mvc:View
	controllerName="zgpms.meilpower.com.controller.InwardGatePass"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
xmlns:layout="sap.ui.layout"
	xmlns:core="sap.ui.core"
	height="100%">
	<Page title="Inward Gate Pass (RGP Return)" class="sapUiContentPadding gpmsPage">
		<headerContent>
			<Button icon="sap-icon://home" press="onNavHome" type="Transparent"/>
		</headerContent>
		<content>
			<VBox class="gpmsMainContainer">

				<!-- Search Panel -->
				<Panel expandable="false" class="gpmsPanel sapUiSmallMarginBottom">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://shield" class="sapUiSmallMarginEnd"/>
							<Title text="RGP REFERENCE" level="H3"/>
							<ToolbarSpacer />
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL6 L6 M6 S12" vSpacing="0">
						<VBox class="sapUiSmallMargin">
							<Label text="Search RGP Gate Pass No" required="true" class="gpmsFieldLabel"/>
							<SearchField
								id="rgpSearch"
								placeholder="Enter RGP Gate Pass No..."
								search=".onSearchRGP"
								class="gpmsFieldInput"
								width="100%"/>
						</VBox>
					</layout:Grid>
				</Panel>

				<!-- Gate Pass Details Panel -->
				<Panel expandable="true" expanded="true" class="gpmsPanel sapUiSmallMarginBottom">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://header" class="sapUiSmallMarginEnd"/>
							<Title text="GATE PASS DETAILS" level="H3"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL4 L4 M6 S12" vSpacing="0">

						<VBox class="sapUiSmallMargin">
							<Label text="Gate Pass Number" class="gpmsFieldLabel"/>
							<Input value="{inward>/GatePassNo}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Gate Pass Date" class="gpmsFieldLabel"/>
							<Input value="{inward>/GatePassDate}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Due Date" class="gpmsFieldLabel"/>
							<Input value="{inward>/DueDate}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Revised Due Date" class="gpmsFieldLabel"/>
							<DatePicker
								value="{inward>/RevisedDueDate}"
								displayFormat="dd-MM-yyyy"
								class="gpmsFieldInput"
								width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Received Date" class="gpmsFieldLabel"/>
							<DatePicker
								value="{inward>/ReceivedDate}"
								displayFormat="dd-MM-yyyy"
								class="gpmsFieldInput"
								width="100%"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Department" class="gpmsFieldLabel"/>
							<Input value="{inward>/Department}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor" class="gpmsFieldLabel"/>
							<Input value="{inward>/VendorName}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor GST" class="gpmsFieldLabel"/>
							<Input value="{inward>/VendorGST}" editable="false" class="gpmsFieldInput"/>
						</VBox>

					</layout:Grid>
				</Panel>

				<!-- Items Table Panel -->
				<Panel expandable="true" expanded="true" class="gpmsPanel">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://list" class="sapUiSmallMarginEnd"/>
							<Title text="TABLE OF ITEMS" level="H3"/>
						</Toolbar>
					</headerToolbar>
					<Table items="{inward>/items}" class="gpmsItemTable">
						<columns>
							<Column><Text text="Material" class="gpmsHeaderText"/></Column>
							<Column hAlign="End" width="9rem"><Text text="Sent Qty" class="gpmsHeaderText"/></Column>
							<Column hAlign="End" width="10rem"><Text text="Received Qty" class="gpmsHeaderText"/></Column>
							<Column hAlign="End" width="9rem"><Text text="Balance Qty" class="gpmsHeaderText"/></Column>
							<Column width="5rem"><Text text="UOM" class="gpmsHeaderText"/></Column>
						</columns>
						<items>
							<ColumnListItem>
								<cells>
									<VBox>
										<Text text="{inward>material}" class="gpmsSnoText"/>
										<Text text="{inward>materialName}" class="sapUiTinyMarginTop"/>
									</VBox>
									<Text text="{path: 'inward>sentQty', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 3, maxFractionDigits: 3}}" textAlign="Right"/>
									<Input
										value="{inward>recvdQty}"
										liveChange=".onQtyChange"
										type="Text"
										textAlign="Right"
										class="gpmsTableInput"/>
									<ObjectNumber
										number="{path: 'inward>balQty', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 3, maxFractionDigits: 3}}"
										state="{= ${inward>balQty} > 0 ? 'Warning' : 'Success'}"/>
									<Text text="{inward>uom}"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</Panel>

	


				<!-- Final Summary -->
				<HBox justifyContent="End" alignItems="Center" class="sapUiMediumMarginTop sapUiLargeMarginEnd">
					<VBox alignItems="End">
						<Label text="TOTAL AMOUNT (RS.)" class="gpmsTotalLabel"/>
						<Text text="{inward>/FinalTotal}" class="gpmsTotalAmount"/>
					</VBox>
				</HBox>
            </VBox>
        </content>
		<footer>
			<Toolbar class="gpmsFooterBar">
				<ToolbarSpacer/>
				<Button text="SUBMIT INWARD GATE PASS" type="Accept" press=".onPostInward" icon="sap-icon://sys-add" class="gpmsSubmitBtn sapUiSmallMarginEnd" enabled="{= ${inward>/items}.length > 0 }"/>
			</Toolbar>
		</footer>
	</Page>
</mvc:View>
