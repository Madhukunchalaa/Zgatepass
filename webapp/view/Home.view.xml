<mvc:View
	controllerName="zgpms.meilpower.com.controller.Home"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:f="sap.f"
	xmlns:core="sap.ui.core"
	height="100%">
	<Page title="Dashboard" class="gpmsDashboardPage" showHeader="false">
		<content>
			<VBox class="gpmsDashboardHero" alignItems="Center" justifyContent="Center">
				<VBox alignItems="Center" class="gpmsHeroTextContainer">
					<Title text="GATE PASS MANAGEMENT SYSTEM" level="H1" class="gpmsHeroTitle"/>
					<Text text="Industrial Logistics &amp; Security Control Dashboard" class="gpmsHeroSubTitle"/>
				</VBox>

				<HBox wrap="Wrap" justifyContent="Center" class="gpmsDashboardCardsContainer">
					<!-- NRGP Card -->
					<GenericTile class="gpmsDashCard nrgpCard" press=".onPressNRGP" header="NRGP REQUEST" subheader="Non-Returnable Gate Pass">
						<TileContent>
							<core:Icon src="sap-icon://add-document" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- RGP Card -->
					<GenericTile class="gpmsDashCard rgpCard" press=".onPressRGP" header="RGP REQUEST" subheader="Returnable Gate Pass">
						<TileContent>
							<core:Icon src="sap-icon://shipping-status" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Analytics Card -->
					<GenericTile class="gpmsDashCard reportsCard" press=".onGenericTileAnalyticsPress" header="REPORTS" subheader="View Statistics &amp; Logs">
						<TileContent>
							<core:Icon src="sap-icon://business-objects-experience" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Inward Gate Pass Card -->
					<GenericTile class="gpmsDashCard inwardCard" press=".onPressInward" header="INWARD GATE PASS" subheader="Return Items (RGP)">
						<TileContent>
							<core:Icon src="sap-icon://down-back" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Out Gate Pass Card -->
					<GenericTile class="gpmsDashCard outCard" press=".onPressOutGatePass" header="OUT GATE PASS" subheader="Generate &amp; Print Pass">
						<TileContent>
							<core:Icon src="sap-icon://shipping-status" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>
					<GenericTile class="gpmsDashCard listCard"
    press=".onPressGatePassList"
    header="GATE PASS LIST"
    subheader="View All Requests">

    <TileContent>
        <core:Icon src="sap-icon://list" class="gpmsCardIcon"/>
    </TileContent>

</GenericTile>
				</HBox>
			</VBox>
		</content>
	</Page>
</mvc:View>
