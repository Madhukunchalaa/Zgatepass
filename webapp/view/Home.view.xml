<mvc:View
	controllerName="zgpms.meilpower.com.controller.Home"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:f="sap.f"
	xmlns:core="sap.ui.core"
	height="100%">
	<Page title="Dashboard" class="gpmsDashboardPage" showHeader="false">
		<content>
			<VBox class="gpmsDashboardHero" alignItems="Center" justifyContent="Center">
				<VBox alignItems="Center" class="gpmsHeroTextContainer">
					<Title text="GATE PASS MANAGEMENT SYSTEM" level="H1" class="gpmsHeroTitle"/>
					<Text text="Industrial Logistics &amp; Security Control Dashboard" class="gpmsHeroSubTitle"/>
				</VBox>

				<HBox wrap="Wrap" justifyContent="Center" class="gpmsDashboardCardsContainer">
					<!-- NRGP Card -->
					<GenericTile class="gpmsDashCard nrgpCard" press=".onPressNRGP" header="NRGP REQUEST" subheader="Non-Returnable Gate Pass" visible="{= !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://add-document" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- RGP Card -->
					<GenericTile class="gpmsDashCard rgpCard" press=".onPressRGP" header="RGP REQUEST" subheader="Returnable Gate Pass" visible="{= !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://shipping-status" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Analytics Card -->
					<GenericTile class="gpmsDashCard reportsCard" press=".onGenericTileAnalyticsPress" header="Analytics" subheader="View Statistics &amp; Logs" visible="{= !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://business-objects-experience" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Excel Reports Download Card -->
					<GenericTile class="gpmsDashCard reportsCard" press=".onGenericTileExcelReportsPress" header="EXCEL REPORTS" subheader="Download All Reports" visible="{= !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://excel-attachment" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Inward Gate Pass Card -->
					<GenericTile class="gpmsDashCard inwardCard" press=".onPressInward" header="INWARD GATE PASS" subheader="Return Items (RGP)" visible="{= !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://down-back" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Add Inward Insurance Card -->
					<GenericTile class="gpmsDashCard insuranceCard" press=".onPressAddInwardInsurance" header="ADD INWARD INSURANCE" subheader="Insurance Details" visible="{= !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://insurance-car" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Inward Insurance List Card -->
					<GenericTile class="gpmsDashCard poListCard" press=".onPressInwardInsuranceList" header="INWARD INSURANCE LIST" subheader="View Insurance Records" visible="{= !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://list" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Out Gate Pass Card -->
					<GenericTile class="gpmsDashCard outCard" press=".onPressOutGatePass" header="OUT GATE PASS" subheader="Generate &amp; Print Pass" visible="{= !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://shipping-status" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Gate Pass Requests List Card -->
					<GenericTile class="gpmsDashCard listCard" press=".onGenericTileGatePassListPress" header="GATE PASS REQUESTS LIST" subheader="View All Requests">
						<TileContent footer="Pending Requests">
							<NumericContent value="{hodCounts>/gatePassListCount}" withMargin="false" valueColor="Critical"/>
						</TileContent>
					</GenericTile>

					<!-- Gate Pass List Card -->
					<GenericTile class="gpmsDashCard nrgpListCard" press=".onPressNRGPList" header="GATE PASS LIST" subheader="Out Gate Pass Records" visible="{= !${user>/IsGatepassUserOnly} }">
						<TileContent footer="Total Records">
							<NumericContent value="{hodCounts>/nrgpListCount}" withMargin="false" valueColor="Good"/>
						</TileContent>
					</GenericTile>

					<!-- Gate Pass with PO Card -->
					<GenericTile class="gpmsDashCard poCard" press=".onGenericTileGatePassWithPOPress" header="CREATE ENTRIES" subheader="Create Gate Entry (PO/PCP)" visible="{= !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://purchase-order" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- PO List Card -->
					<GenericTile class="gpmsDashCard poListCard" press=".onPressPOList" header="PO LIST" subheader="View Purchase Orders" visible="{= !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://list" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- IRGP Card -->
					<GenericTile class="gpmsDashCard irgpCard" press=".onPressIRGP" header="IRGP WORKFLOW" subheader="Internal Returnable GP" visible="{= !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://process" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Add PCP Card -->
					<GenericTile class="gpmsDashCard pcpCard" press=".onPressAddPCP" header="GATE ENTRY LIST" subheader="View Gate Entry Records" visible="{= !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://lead" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Ash Gate Pass Card -->
					<GenericTile class="gpmsDashCard ashCard" press=".onPressAshGatePassCreation" header="ASH GP" subheader="Ash Disposal Creation" visible="{= !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://factory" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Ash Gate Pass Request Card -->
					<GenericTile class="gpmsDashCard ashCard" press=".onPressAshGatePassRequest" header="ASH GP REQUEST" subheader="Ash Gate Pass Request" visible="{= !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://request" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Ash Gate Pass Request List Card -->
					<GenericTile class="gpmsDashCard ashListCard" press=".onPressAshGatePassRequestList" header="ASH GP REQ LIST" subheader="Ash Request Approvals">
						<TileContent footer="Total Records">
							<NumericContent value="{hodCounts>/ashGpReqListCount}" withMargin="false" valueColor="Critical"/>
						</TileContent>
					</GenericTile>

					<!-- Ash Gate Pass List Card -->
					<GenericTile class="gpmsDashCard ashListCard" press=".onPressAshGatePassList" header="ASH GP LIST" subheader="Ash Gate Passes">
						<TileContent footer="Total Records">
							<NumericContent value="{hodCounts>/ashGpListCount}" withMargin="false" valueColor="Good"/>
						</TileContent>
					</GenericTile>

					<!-- Scrap Request Card -->
					<GenericTile class="gpmsDashCard" press=".onPressScrapRequestCreation" header="SCRAP REQUEST" subheader="Scrap Collection Request" visible="{= !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://delete" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Scrap Request List Card -->
					<GenericTile class="gpmsDashCard" press=".onPressScrapRequestList" header="SCRAP REQUEST LIST" subheader="Scrap Approvals">
						<TileContent>
							<core:Icon src="sap-icon://list" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Scrap Entity List Card -->
					<GenericTile class="gpmsDashCard" press=".onPressScrapInventory" header="SCRAP 	INVENTORY LIST" subheader="Scrap Stock Inventory">
						<TileContent>
							<core:Icon src="sap-icon://inventory" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Add Scrap Gatepass Card -->
					<GenericTile class="gpmsDashCard" press=".onPressScrapGatepassCreation" header="ADD SCRAP GATEPASS" subheader="Scrap Sale &amp; Outward" visible="{= !${user>/IsGatepassUserOnly} &amp;&amp; !${user>/IsHodUser} }">
						<TileContent>
							<core:Icon src="sap-icon://sales-document" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Scrap Gatepass List Card -->
					<GenericTile class="gpmsDashCard scrapGpListCard" press=".onPressScrapGatepassList" header="SCRAP GATE PASS LIST" subheader="View Scrap Gate Passes" visible="{= !${user>/IsGatepassUserOnly} }">
						<TileContent footer="Total Records">
							<NumericContent value="{hodCounts>/scrapGpListCount}" withMargin="false" valueColor="Good"/>
						</TileContent>
					</GenericTile>

					<!-- PCP List Card -->
					<GenericTile class="gpmsDashCard pcpManageCard" press=".onPressPCPManageList" header="PCP LIST" subheader="Petty Cash Purchases">
						<TileContent>
							<core:Icon src="sap-icon://money-bills" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>

					<!-- Inspection List Card -->
					<GenericTile class="gpmsDashCard inspectionCard" press=".onPressInspectionList" header="INSPECTION LIST" subheader="Gate Entry Inspections">
						<TileContent>
							<core:Icon src="sap-icon://inspection" class="gpmsCardIcon"/>
						</TileContent>
					</GenericTile>
					
				</HBox>
			</VBox>
		</content>
	</Page>
</mvc:View>
