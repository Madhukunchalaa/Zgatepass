<mvc:View
	controllerName="zgpms.meilpower.com.controller.GatePassWithPO"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:layout="sap.ui.layout"
	xmlns:core="sap.ui.core"
	height="100%">
	<Page title="{= ${gpo>/SourceType} === 'PettyCash' ? 'Gate Entry against Petty Cash' : ${gpo>/SourceType} ? 'Gate Entry against PO / Others' : 'Gate Entry' }" class="sapUiContentPadding gpmsPage" showNavButton="{gpo>/isExisting}" navButtonPress=".onNavBack">
		<headerContent>
			<Button icon="sap-icon://home" press="onNavHome" type="Transparent"/>
		</headerContent>
		<content>
			<VBox class="gpmsMainContainer">

				<!-- Header Details Panel -->
				<Panel expandable="true" expanded="true" class="gpmsPanel sapUiSmallMarginBottom">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://header" class="sapUiSmallMarginEnd"/>
							<Title text="GATE ENTRY DETAILS" level="H3"/>
							<ToolbarSpacer/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL4 L4 M6 S12" vSpacing="0" class="gpmsGridForm">

						<VBox class="sapUiSmallMargin">
							<Label text="GE Date" required="true" class="gpmsFieldLabel"/>
							<DatePicker
								id="idGEDate"
								value="{gpo>/GEDate}"
								displayFormat="dd-MM-yyyy"
								valueFormat="yyyy-MM-dd"
								class="gpmsFieldInput"
								width="100%"
								editable="{= !${gpo>/isExisting} }"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="Source Type" required="true" class="gpmsFieldLabel"/>
							<Select id="idSourceType" selectedKey="{gpo>/SourceType}" width="100%" class="gpmsFieldInput" change=".onSourceTypeChange" enabled="{= !${gpo>/isExisting} }">
								<items>
									<core:Item key="" text="Select Type (PO/PCP/RGP/FREE)"/>
									<core:Item key="PO_RGP" text="Purchase Order (PO) / Returnable GatePass (RGP)"/>
									<core:Item key="PO" text="Only Purchase Order (PO)"/>
									<core:Item key="PettyCash" text="Petty Cash Purchase(PCP)"/>
									<core:Item key="FREE" text="FREE/SAMPLEs"/>
									<core:Item key="SERVICE" text="SERVICE"/>
									<core:Item key="STAFF_WELFARE" text="STAFF WELFARE"/>
								</items>
							</Select>
						</VBox>

						<VBox class="sapUiSmallMargin" visible="true">
							<Label text="PO Number" class="gpmsFieldLabel"/>
							<Input id="idPurchaseOrder" value="{gpo>/PurchaseOrder}" placeholder="Enter PO Number" class="gpmsFieldInput" showValueHelp="true" valueHelpRequest=".onPOValueHelp" change=".onPOChange" editable="{= !${gpo>/isExisting} }"/>
						</VBox>

						<!-- Standard Vendor Code Input for PO Mode -->
						<VBox class="sapUiSmallMargin" visible="true">
							<Label text="Vendor Code" class="gpmsFieldLabel"/>
							<Input id="idVendor" value="{gpo>/Vendor}" placeholder="Enter Vendor Code" class="gpmsFieldInput" editable="{= !${gpo>/isExisting} }"/>
						</VBox>
  
 
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor Name" required="{= ${gpo>/SourceType} === 'PettyCash' }" class="gpmsFieldLabel"/>
							<Input id="idVendorDesc" value="{gpo>/VendorDesc}" placeholder="Vendor Name" class="gpmsFieldInput" editable="{= !${gpo>/isExisting} }"/>
						</VBox>
 
						<VBox class="sapUiSmallMargin">
							<Label text="Plant" required="true" class="gpmsFieldLabel"/>
							<Input id="idPlant" value="{gpo>/Plant}" placeholder="Enter Plant" class="gpmsFieldInput" change=".onPlantChange" editable="{= !${gpo>/isExisting} }"/>
						</VBox>
 
						<VBox class="sapUiSmallMargin">
							<Label text="Department" required="true" class="gpmsFieldLabel"/>
							<Input value="{gpo>/Department}" class="gpmsFieldInput" editable="false"
								visible="{= ${gpo>/SourceType} === 'PO' || ${gpo>/SourceType} === 'PO_RGP' }"/>
							<Select selectedKey="{gpo>/Department}" class="gpmsFieldInput" width="100%"
								visible="{= ${gpo>/SourceType} !== 'PO' &amp;&amp; ${gpo>/SourceType} !== 'PO_RGP' }"
								enabled="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }">
								<items>
									<core:Item key="" text="Select Department"/>
									<core:Item key="ADMIN" text="ADMIN"/>
									<core:Item key="C And I" text="C And I"/>
									<core:Item key="CHEMICAL" text="CHEMICAL"/>
									<core:Item key="CIVIL" text="CIVIL"/>
									<core:Item key="ELECTRICAL" text="ELECTRICAL"/>
									<core:Item key="PERFORMANCE" text="PERFORMANCE"/>
									<core:Item key="IT" text="IT"/>
									<core:Item key="MECHANICAL" text="MECHANICAL"/>
									<core:Item key="OPERATION" text="OPERATION"/>
									<core:Item key="SAFETY" text="SAFETY"/>
									<core:Item key="STORES" text="STORES"/>
									<core:Item key="FUEL" text="FUEL"/>
									<core:Item key="ENVIRONMENT" text="ENVIRONMENT"/>
									<core:Item key="F&amp;A" text="F&amp;A"/>
									<core:Item key="PURCHASE" text="PURCHASE"/>
									<core:Item key="OTHERS" text="OTHERS"/>
								</items>
							</Select>
						</VBox>
 
						<VBox class="sapUiSmallMargin">
							<Label text="RGP Number" class="gpmsFieldLabel"/>
							<Input id="idRGPNumber" value="{gpo>/RGPNumber}" placeholder="Enter RGP Number" class="gpmsFieldInput gpmsPoHighlightedField" editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
						</VBox>
 
						<VBox class="sapUiSmallMargin">
							<Label text="DC / Invoice No" class="gpmsFieldLabel"/>
							<Input id="idDCNumber" value="{gpo>/DCNumber}" placeholder="Enter DC or Invoice No" class="gpmsFieldInput" editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
						</VBox>

						<VBox class="sapUiSmallMargin" visible="true">
							<Label text="DC Date" class="gpmsFieldLabel"/>
							<DatePicker
								id="idDCdateDatePicker"
								value="{gpo>/DCdate}"
								displayFormat="dd-MM-yyyy"
								valueFormat="yyyy-MM-dd"
								class="gpmsFieldInput"
								width="100%"
								editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
						</VBox>

						<VBox class="sapUiSmallMargin" visible="{= ${gpo>/SourceType} === 'PettyCash' }">
							<Label text="PCP No" class="gpmsFieldLabel"/>
							<Input id="idPCPNo" value="{gpo>/PCPNo}" placeholder="Enter PCP No" class="gpmsFieldInput gpmsPoHighlightedField" editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
						</VBox>
 
						<VBox class="sapUiSmallMargin">
							<Label text="Budget Code" class="gpmsFieldLabel"/>
							<Input id="idBudgetCode" value="{gpo>/BudgetCode}" placeholder="Enter Budget Code" class="gpmsFieldInput gpmsPoHighlightedField" editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
						</VBox>
 
						<VBox class="sapUiSmallMargin">
							<Label text="Total Cost (Rs.)" class="gpmsFieldLabel"/>
							<Input id="idTotalCost" value="{gpo>/TotalCost}" placeholder="Enter Total Cost" type="Text" class="gpmsFieldInput" editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
						</VBox>
 
						<VBox class="sapUiSmallMargin">
							<Label text="RR No" class="gpmsFieldLabel"/>
							<Input id="idRRNo" value="{gpo>/RRNo}" placeholder="Enter RR Details" class="gpmsFieldInput" editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
						</VBox>

						<VBox class="sapUiSmallMargin" visible="true">
							<Label text="Inspection Status" class="gpmsFieldLabel"/>
							<Select id="idInspectionStatus" selectedKey="{gpo>/InspectionStatus}" width="100%" class="gpmsFieldInput" enabled="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }">
								<items>
									<core:Item key="Open" text="Open"/>
									<core:Item key="Pending" text="Pending"/>
									<core:Item key="Completed" text="Completed"/>
								</items>
							</Select>
						</VBox>

						<VBox class="sapUiSmallMargin" visible="true">
							<Label text="Inspected Date" class="gpmsFieldLabel"/>
							<DatePicker
								id="idInspectedDate"
								value="{gpo>/Inspectiondate}"
								displayFormat="dd-MM-yyyy"
								valueFormat="yyyy-MM-dd"
								class="gpmsFieldInput"
								width="100%"
								editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="Gate Entry No" class="gpmsFieldLabel"/>
							<Input value="{gpo>/GateEntryNo}" placeholder="Enter Gate Entry No" class="gpmsFieldInput" submit=".onGateEntryNoChange" change=".onGateEntryNoChange" editable="{= !${gpo>/isExisting} }"/>
						</VBox>

						<VBox class="sapUiSmallMargin" visible="{= ${gpo>/isExisting} &amp;&amp; ${gpo>/SourceType} !== 'PettyCash' &amp;&amp; (!!${gpo>/GatePassNo} || !!${gpo>/PCPNo}) }">
							<Label text="Gate Pass No" class="gpmsFieldLabel"/>
							<Input value="{= ${gpo>/GatePassNo} || ${gpo>/PCPNo} }" editable="false" class="gpmsFieldInput"/>
						</VBox>

						<!-- Dynamic Vendor ComboBox for Petty Cash Mode (Moved here so it doesn't affect column grids) -->
						<VBox class="sapUiSmallMargin" visible="false">
							<Label text="Vendor Code / Name" required="true" class="gpmsFieldLabel"/>
							<ComboBox
								id="idVendorSelect"
								selectedKey="{gpo>/Vendor}"
								placeholder="Search and select vendor..."
								selectionChange=".onVendorSelect"
								class="gpmsFieldInput"
								width="100%"
								items="{path: 'vendors>/results', templateShareable: false}">
								<core:ListItem key="{vendors>Vendor}" text="{vendors>VendorName}" additionalText="{vendors>Vendor}"/>
							</ComboBox>
						</VBox>

					</layout:Grid>

					<VBox class="sapUiSmallMargin sapUiSmallMarginTop">
						<Label text="Remarks" class="gpmsFieldLabel"/>
						<TextArea id="idRemarks" value="{gpo>/Remarks}" placeholder="Enter remarks..." rows="3" width="100%" class="gpmsTextArea" editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
					</VBox>

				</Panel>

				<!-- Items Panel (PO only) -->
				<Panel expandable="true" expanded="true" class="gpmsPanel sapUiSmallMarginBottom"
					visible="{= ${gpo>/SourceType} === 'PO' || !${gpo>/SourceType} }">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://list" class="sapUiSmallMarginEnd"/>
							<Title text="ITEMS" level="H3"/>
							<ToolbarSpacer/>
							<Button text="Add Item" icon="sap-icon://add" press=".onAddItem" type="Transparent" class="gpmsAddBtn" visible="{= !${gpo>/isExisting} }"/>
						</Toolbar>
					</headerToolbar>
					<Table id="idItemsTable" items="{gpo>/GateInPoNav}" class="gpmsItemTable">
						<columns>
							<Column width="6rem"><Text text="Item No" class="gpmsHeaderText"/></Column>
							<Column><Text text="Item Description" class="gpmsHeaderText"/></Column>
							<Column width="9rem" hAlign="Right"><Text text="PO Qty" class="gpmsHeaderText"/></Column>
							<Column width="9rem" hAlign="Right"><Text text="Received Qty" class="gpmsHeaderText"/></Column>
							<Column width="9rem" hAlign="Right"><Text text="Balance Qty" class="gpmsHeaderText"/></Column>
							<Column width="6rem"><Text text="UOM" class="gpmsHeaderText"/></Column>
							<Column width="9rem"><Text text="Gate Pass No" class="gpmsHeaderText"/></Column>
							<Column width="3rem" visible="{= !${gpo>/isExisting} }"/>
						</columns>
						<items>
							<ColumnListItem>
								<cells>
									<Input value="{gpo>ItemNo}" placeholder="Item No" class="gpmsTableInput" editable="{= !${gpo>/isExisting} }"/>
									<Input value="{gpo>ItemDescription}" placeholder="Item Description" class="gpmsTableInput" editable="{= !${gpo>/isExisting} }"/>
									<Input value="{gpo>POQuantity}" placeholder="0.000" type="Text" textAlign="Right" class="gpmsTableInput" editable="{= !${gpo>/isExisting} }" liveChange=".onPOQuantityInputLiveChange"/>
									<Input value="{gpo>RecievedQuantity}" placeholder="0.000" type="Text" textAlign="Right" class="gpmsTableInput" editable="{= ${gpo>/isEditMode} }"/>
									<Text text="{path: 'gpo>BalanceQuantity', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 3, maxFractionDigits: 3}}" textAlign="Right"/>
									<Text text="{gpo>UOM}"/>
									<Text text="{gpo>GatePassNo}"/>
									<Button icon="sap-icon://delete" type="Transparent" press=".onDeleteItem" class="gpmsDeleteBtn" visible="{= !${gpo>/isExisting} }"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</Panel>

				<!-- Items Panel (Non-PO: PO_RGP, PettyCash, FREE, SERVICE, STAFF_WELFARE) -->
				<Panel expandable="true" expanded="true" class="gpmsPanel sapUiSmallMarginBottom"
					visible="{= ${gpo>/SourceType} !== 'PO' &amp;&amp; !!${gpo>/SourceType} }">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://list" class="sapUiSmallMarginEnd"/>
							<Title text="ITEMS" level="H3"/>
							<ToolbarSpacer/>
							<Button text="Add Item" icon="sap-icon://add" press=".onAddItem" type="Transparent" class="gpmsAddBtn" visible="{= !${gpo>/isExisting} }"/>
						</Toolbar>
					</headerToolbar>
					<Table id="idSimpleItemsTable" items="{gpo>/GateInPoNav}" class="gpmsItemTable">
						<columns>
							<Column><Text text="Item Description" class="gpmsHeaderText"/></Column>
							<Column width="10rem" hAlign="Right"><Text text="Qty" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="UOM" class="gpmsHeaderText"/></Column>
							<Column width="3rem" visible="{= !${gpo>/isExisting} }"/>
						</columns>
						<items>
							<ColumnListItem>
								<cells>
									<Input value="{gpo>ItemDescription}" placeholder="Item Description" class="gpmsTableInput" editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
									<Input value="{gpo>RecievedQuantity}" placeholder="0.00" type="Number" textAlign="Right" class="gpmsTableInput" editable="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
									<Select selectedKey="{gpo>UOM}" class="gpmsTableInput" width="100%"
										enabled="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }">
										<items>
											<core:Item key="Number" text="Number"/>
											<core:Item key="Feet" text="Feet"/>
											<core:Item key="Kilogram" text="Kilogram"/>
											<core:Item key="Length" text="Length"/>
											<core:Item key="Litre" text="Litre"/>
											<core:Item key="Load" text="Load"/>
											<core:Item key="Lot" text="Lot"/>
											<core:Item key="Meters" text="Meters"/>
											<core:Item key="Metric Tons" text="Metric Tons"/>
											<core:Item key="Pair" text="Pair"/>
											<core:Item key="Roll" text="Roll"/>
											<core:Item key="Set" text="Set"/>
											<core:Item key="Sheet" text="Sheet"/>
											<core:Item key="Square Feet" text="Square Feet"/>
											<core:Item key="Square Meter" text="Square Meter"/>
											<core:Item key="Item" text="Item"/>
											<core:Item key="Pack" text="Pack"/>
											<core:Item key="Days" text="Days"/>
											<core:Item key="Pocket" text="Pocket"/>
											<core:Item key="Ream" text="Ream"/>
											<core:Item key="Tons" text="Tons"/>
											<core:Item key="Unit" text="Unit"/>
											<core:Item key="Month" text="Month"/>
										</items>
									</Select>
									<Button icon="sap-icon://delete" type="Transparent" press=".onDeleteItem" class="gpmsDeleteBtn" visible="{= !${gpo>/isExisting} }"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</Panel>

			</VBox>
		</content>
		<footer>
			<Toolbar class="gpmsFooterBar">
				<ToolbarSpacer/>
				<Button text="RESET" press=".onReset" icon="sap-icon://refresh" class="sapUiSmallMarginEnd" visible="{= !${gpo>/isExisting} }"/>
				<Button text="{= ${gpo>/isExisting} ? 'UPDATE ENTRY' : 'ENTER GATE ENTRY' }" type="Accept" press=".onSubmit" icon="sap-icon://sys-add" class="gpmsSubmitBtn sapUiSmallMarginEnd" visible="{= !${gpo>/isExisting} || ${gpo>/isEditMode} }"/>
			</Toolbar>
		</footer>
	</Page>
</mvc:View>
