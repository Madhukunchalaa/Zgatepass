<mvc:View
	controllerName="zgpms.meilpower.com.controller.RGPDetail"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:layout="sap.ui.layout"
	xmlns:core="sap.ui.core"
	height="100%">

	<Page id="idRGPDetailPage" title="RGP Gate Pass Detail" class="sapUiContentPadding gpmsPage">
		<headerContent>
			<Button icon="sap-icon://nav-back" press=".onButtonNavBackPress" type="Transparent" tooltip="Back to List"/>
		</headerContent>

		<content>
			<VBox class="gpmsMainContainer">

				<!-- Gate Pass Header Banner -->
				<Panel expandable="false" class="gpmsPanel sapUiSmallMarginBottom">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://document" class="sapUiSmallMarginEnd"/>
							<Title text="RGP GATE PASS DETAILS" level="H3"/>
							<ToolbarSpacer/>
							<ObjectStatus text="{= 'Req No: ' + ${rgp>/GatePassreqNo}}" state="None" icon="sap-icon://detail-view" class="sapUiSmallMarginEnd" visible="{= !!${rgp>/GatePassreqNo} }"/>
							<ObjectStatus text="{= 'GP No: ' + ${rgp>/GatePassNo}}" state="Information" icon="sap-icon://tag" class="sapUiSmallMarginEnd" visible="{= !!${rgp>/GatePassNo} }"/>
							<ObjectStatus text="{= ${rgp>/GPStatus} === 'AWAITING FOR VENDOR ACKNOWLEDGEMENT' ? 'Awaiting for Return' : (${rgp>/GPStatus} ? ${rgp>/GPStatus} : 'Not Set')}" state="{rgp>/StatusState}" icon="sap-icon://status-in-process"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL3 L3 M6 S12" vSpacing="0">
						<VBox class="sapUiSmallMargin">
							<Label text="Gate Pass No." class="gpmsFieldLabel"/>
							<Input value="{rgp>/GatePassNo}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Request No." class="gpmsFieldLabel"/>
							<Input value="{rgp>/GatePassreqNo}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Gate Pass Date" class="gpmsFieldLabel"/>
							<Input value="{rgp>/GatePassDate}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Plant" class="gpmsFieldLabel"/>
							<Input value="{rgp>/Plant}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Department" class="gpmsFieldLabel"/>
							<Input value="{rgp>/Department}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor" class="gpmsFieldLabel"/>
							<Input value="{rgp>/Vendor}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor GST" class="gpmsFieldLabel"/>
							<Input value="{rgp>/VendorGST}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor Person" class="gpmsFieldLabel"/>
							<Input value="{rgp>/VendorPerson}" placeholder="Enter contact person" class="gpmsFieldInput" editable="{rgp>/isEditable}"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<layoutData>
								<layout:GridData span="XL4 L4 M12 S12"/>
							</layoutData>
							<Label text="City / Address" class="gpmsFieldLabel"/>
							<Input value="{rgp>/VendorAddress}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Due Date (Return By)" class="gpmsFieldLabel"/>
							<Input value="{rgp>/ReturnableDate}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<layoutData>
								<layout:GridData span="XL6 L6 M12 S12"/>
							</layoutData>
							<Label text="Common Description" class="gpmsFieldLabel"/>
							<Input value="{rgp>/CommonDesc}" editable="false" class="gpmsFieldInput"/>
						</VBox>
					</layout:Grid>
				</Panel>

				<!-- Table of Items -->
				<Panel expandable="true" expanded="true" class="gpmsPanel sapUiSmallMarginBottom">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://table-view" class="sapUiSmallMarginEnd"/>
							<Title text="TABLE OF ITEMS" level="H3"/>
							<ToolbarSpacer/>
							<Button id="idRGPCopyItemsBtn" icon="sap-icon://copy" text="Copy" press=".onCopyItemsToClipboard" tooltip="Copy items to clipboard" class="sapUiTinyMarginEnd"/>
							<Button id="idRGPPrintItemsBtn" icon="sap-icon://print" text="Print" press=".onPrintItems" tooltip="Print item table"/>
						</Toolbar>
					</headerToolbar>
					<Table items="{rgp>/items}" class="gpmsItemTable" alternateRowColors="true">
						<columns>
							<Column width="3rem" hAlign="Center">
								<Text text="#" class="gpmsHeaderText" wrapping="false"/>
							</Column>
							<Column width="9rem">
								<Text text="Material" class="gpmsHeaderText" wrapping="false"/>
							</Column>
							<Column width="15rem">
								<Text text="Material Description" class="gpmsHeaderText" wrapping="false"/>
							</Column>
							<Column width="9rem">
								<Text text="HSN Code" class="gpmsHeaderText" wrapping="false"/>
							</Column>
							<Column width="5rem">
								<Text text="UOM" class="gpmsHeaderText" wrapping="false"/>
							</Column>
							<Column width="9rem" hAlign="Right">
								<Text text="Rate (Rs.)" class="gpmsHeaderText" wrapping="false"/>
							</Column>
							<Column width="9rem" hAlign="Right">
								<Text text="Sent Qty" class="gpmsHeaderText" wrapping="false"/>
							</Column>
							<Column width="10rem" hAlign="Right">
								<Text text="Received Qty" class="gpmsHeaderText" wrapping="false"/>
							</Column>
							<Column width="9rem" hAlign="Right">
								<Text text="Balance Qty" class="gpmsHeaderText" wrapping="false"/>
							</Column>
							<Column width="10rem" hAlign="Right">
								<Text text="Total (Rs.)" class="gpmsHeaderText" wrapping="false"/>
							</Column>
							<Column width="12rem">
								<Text text="Remarks" class="gpmsHeaderText" wrapping="false"/>
							</Column>
						</columns>
						<items>
							<ColumnListItem>
								<cells>
									<Text text="{rgp>sno}" wrapping="false"/>
									<Text text="{rgp>Material}" wrapping="false"/>
									<Text text="{rgp>MaterialDesc}" wrapping="true"/>
									<Text text="{rgp>HSNCode}" wrapping="false"/>
									<Text text="{rgp>UOM}" wrapping="false"/>
									<Text text="{path: 'rgp>ItemNetPrice', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 2, maxFractionDigits: 2}}" textAlign="Right" wrapping="false"/>
									<Text text="{path: 'rgp>SentQuantity', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 3, maxFractionDigits: 3}}" textAlign="Right" wrapping="false"/>
									<Input value="{path: 'rgp>RecievedQuantity', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 3, maxFractionDigits: 3}}"
										textAlign="Right" valueLiveUpdate="true" width="100%"
										liveChange=".onRecievedQuantityInputLiveChange" class="gpmsTableInput"
										editable="{rgp>/isEditable}"/>
									<Text text="{path: 'rgp>BalanceQuantity', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 3, maxFractionDigits: 3}}" textAlign="Right" wrapping="false" class="gpmsBoldText"/>
									<Text text="{path: 'rgp>Totalvalue', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 2, maxFractionDigits: 2}}" textAlign="Right" wrapping="false"/>
									<Text text="{rgp>Remarks}" wrapping="true"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</Panel>

				<!-- Remarks -->
				<Panel expandable="true" expanded="true" class="gpmsPanel sapUiSmallMarginBottom">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://notes" class="sapUiSmallMarginEnd"/>
							<Title text="REMARKS" level="H3"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL4 L4 M6 S12" vSpacing="0" class="sapUiSmallMargin">
						<VBox class="sapUiSmallMargin">
							<Label text="Remarks" class="gpmsFieldLabel"/>
							<TextArea value="{rgp>/UserRemarks}" editable="false" width="100%" rows="3" class="gpmsTextArea"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="HOD Remarks" class="gpmsFieldLabel"/>
							<TextArea value="{rgp>/HODRemarks}" editable="false" width="100%" rows="3" class="gpmsTextArea"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Store Remarks" class="gpmsFieldLabel"/>
							<TextArea value="{rgp>/StoreRemarks}" editable="false" width="100%" rows="3" class="gpmsTextArea"/>
						</VBox>
					</layout:Grid>
				</Panel>

				<!-- Logistics & Documents -->
				<Panel expandable="true" expanded="true" class="gpmsPanel sapUiSmallMarginTop">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://shipping-status" class="sapUiSmallMarginEnd"/>
							<Title text="LOGISTICS &amp; DOCUMENTS" level="H3"/>
						</Toolbar>
					</headerToolbar>
					<VBox class="sapUiMediumMargin">
						<RadioButtonGroup columns="2" selectedIndex="{rgp>/DocOptionIndex}" enabled="{rgp>/isEditable}">
							<RadioButton text="DC Not Required" />
							<RadioButton text="DC Required" />
						</RadioButtonGroup>

						<VBox class="sapUiSmallMarginTop">
							<!-- Row 1: Vehicle & Transport By -->
		<HBox wrap="Wrap" class="sapUiTinyMarginBottom">
    <VBox width="48%" class="sapUiSmallMarginEnd">
    <Label text="L.R No." />
    <Input value="{rgp>/LRNumber}"
           placeholder="Enter L.R No." editable="{rgp>/isEditable}"/>
</VBox>

<VBox width="48%">
    <Label text="Vehicle No." />
    <Input value="{rgp>/VehicleNo}"
           placeholder="Enter Vehicle No." editable="{rgp>/isEditable}"/>
</VBox>
</HBox>

<HBox>
    <VBox width="45%">
        <Label text="Transport By" class="gpmsFieldLabel"/>
        <RadioButtonGroup columns="2"
                          selectedIndex="{rgp>/TransportByIndex}"
                          select=".onTransportByChange"
                          class="sapUiTinyMarginTop"
                          enabled="{rgp>/isEditable}">
            <RadioButton text="Self"/>
            <RadioButton text="Vendor"/>
        </RadioButtonGroup>
    </VBox>
</HBox>

							<!-- Row 2: Mode & Transporter Name -->
							<HBox wrap="Wrap" class="sapUiSmallMarginTop">
								<VBox width="50%" class="sapUiSmallMarginEnd">
									<Label text="Mode of Transport" class="gpmsFieldLabel"/>
									<Select selectedKey="{rgp>/ModeOfDisp}" width="100%" class="gpmsFieldInput" enabled="{rgp>/isEditable}">
										<core:Item key="Road" text="By Road"/>
										<core:Item key="Rail" text="By Rail"/>
										<core:Item key="Air" text="By Air"/>
									</Select>
								</VBox>
								<VBox width="45%">
									<Label text="Transporter Name" class="gpmsFieldLabel"/>
									<Input value="{rgp>/TransporterName}" placeholder="Enter Transporter Name" class="gpmsFieldInput" width="100%" editable="{rgp>/isEditable}"/>
								</VBox>
							</HBox>

							<!-- Row 3: Transporter GST & Challan No -->
							<HBox wrap="Wrap" class="sapUiSmallMarginTop">
								<VBox width="50%" class="sapUiSmallMarginEnd">
									<Label text="Transporter GST" class="gpmsFieldLabel"/>
									<Input value="{rgp>/TransporterGST}" placeholder="Enter Transporter GST" class="gpmsFieldInput" width="100%" editable="{rgp>/isEditable}"/>
								</VBox>
								<VBox width="45%">
									<Label text="Challan No." class="gpmsFieldLabel"/>
									<Input value="{rgp>/ChallanNumber}" placeholder="Enter Challan No" class="gpmsFieldInput" width="100%" editable="{rgp>/isEditable}"/>
								</VBox>
							</HBox>

							<!-- Row 4: Extended Return Date -->
							<HBox wrap="Wrap" class="sapUiSmallMarginTop">
								<VBox width="50%" class="sapUiSmallMarginEnd">
									<Label text="Extended Returnable Date" class="gpmsFieldLabel"/>
									<DatePicker value="{rgp>/ExtReturnDate}" valueFormat="dd-MM-yyyy" displayFormat="dd-MM-yyyy" class="gpmsFieldInput" width="100%" editable="{rgp>/isEditable}"/>
								</VBox>
								<VBox width="45%">
									<Label text="E-Way Bill No" class="gpmsFieldLabel"/>
									<Input value="{rgp>/EWayBillNo}" placeholder="Enter E-Way Bill No" class="gpmsFieldInput" width="100%"
										editable="{= ${rgp>/isEditable} &amp;&amp; ${rgp>/DocOptionIndex} === 1}"/>
								</VBox>
							</HBox>

							<!-- Row 5: E-Way Bill Date -->
							<HBox wrap="Wrap" class="sapUiSmallMarginTop">
								<VBox width="50%" class="sapUiSmallMarginEnd">
									<Label text="E-Way Bill Date" class="gpmsFieldLabel"/>
									<DatePicker value="{rgp>/EWayBillDate}" displayFormat="dd-MM-yyyy" class="gpmsFieldInput" width="100%"
										editable="{= ${rgp>/isEditable} &amp;&amp; ${rgp>/DocOptionIndex} === 1}"/>
								</VBox>
							</HBox>

							<!-- Row 6: DC Notes (only when Required) -->
							<VBox class="sapUiSmallMarginTop" visible="{= ${rgp>/DocOptionIndex} === 1}">
								<Label text="DC / DF Notes" class="gpmsFieldLabel"/>
								<TextArea value="{rgp>/DCNotes}" width="100%" rows="2" class="gpmsTextArea" editable="{rgp>/isEditable}"/>
							</VBox>

							<!-- Insurance Required Checkbox -->
							<HBox class="sapUiSmallMarginTop" alignItems="Center">
								<CheckBox id="idInsuranceRequiredRGPCheckBox" text="Insurance Required" selected="{rgp>/InsuranceRequired}" select=".onInsuranceRequiredCheckBoxSelect" enabled="{rgp>/isEditable}"/>
							</HBox>

							<!-- Row 7: Gate Pass Status -->
							<VBox class="sapUiSmallMarginTop">
								<Label text="Gate Pass Status" class="gpmsFieldLabel" required="true"/>
								<Select selectedKey="{rgp>/GPStatus}" width="100%" class="gpmsFieldInput" change=".onSelectStatusChange">
									<core:Item key="" text="Select Status"/>
									<core:Item key="OPEN" text="OPEN"/>
									<core:Item key="AWAITING FOR VENDOR ACKNOWLEDGEMENT" text="Awaiting for Return"/>
									<core:Item key="CLOSED" text="CLOSED"/>
									<core:Item key="CANCELLED" text="CANCELLED"/>
								</Select>
							</VBox>

							<!-- Row 8: Remarks -->
							<VBox class="sapUiSmallMarginTop">
								<Label text="Common Description" class="gpmsFieldLabel"/>
								<TextArea value="{rgp>/CommonDesc}" width="100%" rows="2" class="gpmsTextArea" editable="{rgp>/isEditable}"/>
							</VBox>
						</VBox>

						<!-- Comments Table -->
						<VBox class="sapUiMediumMarginTop">
							<Button text="Add Comment" icon="sap-icon://add" press=".onAddCommentButtonPress" class="gpmsAddBtn sapUiSmallMarginBottom" enabled="{rgp>/isEditable}"/>
							<Table items="{rgp>/CommentsList}" class="gpmsItemTable small">
								<columns>
									<Column><Text text="Comments" class="gpmsHeaderText"/></Column>
									<Column width="10rem"><Text text="Date" class="gpmsHeaderText"/></Column>
									<Column width="3rem"></Column>
								</columns>
								<items>
									<ColumnListItem>
										<cells>
											<Input value="{rgp>text}" placeholder="Enter comment..." class="gpmsTableInput"/>
											<Text text="{rgp>date}"/>
											<Button icon="sap-icon://delete" type="Transparent" press=".onButtonDeleteCommentPress" class="gpmsDeleteBtn"/>
										</cells>
									</ColumnListItem>
								</items>
							</Table>
						</VBox>

						<!-- Action Buttons -->
						<HBox justifyContent="End" class="sapUiLargeMarginTop">
							<Button text="PRINT GATE PASS" type="Emphasized" press=".onPRINTGATEPASSButtonPress"
								icon="sap-icon://print" class="gpmsDocBtn dcBtn sapUiSmallMarginEnd"
								visible="{= !!${rgp>/GatePassNo} }"/>
							<Button text="CANCEL GATE PASS" type="Reject" press=".onCANCELGATEPASSButtonPress"
								icon="sap-icon://cancel" class="gpmsDocBtn rejectBtn sapUiSmallMarginEnd"
								visible="{= !!${rgp>/GatePassNo} &amp;&amp; ${rgp>/GPStatus} !== 'CANCELLED' }"/>
							<Button text="Generate DC" type="Emphasized" press=".onGenerateDCButtonPress"
								class="gpmsDocBtn dcBtn sapUiSmallMarginEnd"
								visible="{= ${rgp>/DocOptionIndex} === 1 &amp;&amp; !!${rgp>/GatePassNo} }"/>
							<Button text="SAVE" type="Accept" press=".onSAVEButtonPress" icon="sap-icon://save" class="gpmsSubmitBtn"/>
						</HBox>
					</VBox>
				</Panel>

				<!-- Total Amount Footer -->
				<HBox justifyContent="End" alignItems="Center" class="sapUiMediumMarginTop sapUiLargeMarginEnd">
					<VBox alignItems="End">
						<Label text="TOTAL AMOUNT (RS.)" class="gpmsTotalLabel"/>
						<Text text="{rgp>/FinalTotal}" class="gpmsTotalAmount"/>
					</VBox>
				</HBox>

			</VBox>
		</content>
	</Page>
</mvc:View>
