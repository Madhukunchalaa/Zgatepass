<mvc:View
    controllerName="zgpms.meilpower.com.controller.GatePassStep2"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    height="100%">

    <Page title="Gate Pass Request" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <VBox class="sapUiSmallMargin">
                <Panel headerText="Gate pass request">
                    <f:SimpleForm editable="true" layout="ColumnLayout" columnsM="2" columnsL="3">
                        <f:content>
                            <Label text="Gate Pass Req No"/>
                            <Input value="{headerModel>/GatePassReqNo}" editable="false"/>

                            
                            

                            <Label text="Plant"/>
                            <Input value="{headerModel>/Plant}" editable="false"/>

                            
                            <Label text="Supplier"/>
                            <ComboBox 
                                selectedKey="{headerModel>/Vendor}" 
                                items="{vendorModel>/}" 
                                selectionChange="onVendorChange"
                                showSecondaryValues="true"
                                filterSecondaryValues="true">
                                <core:Item key="{vendorModel>Vendor}" text="{vendorModel>Vendor}" additionalText="{vendorModel>Name}" />
                            </ComboBox>
                            
                            <Label text="Vendor Name"/>
                            <Input value="{headerModel>/VendorName}" editable="false"/>
                            
                            <Label text="Street and House No"/>
                            <Input value="{headerModel>/Street}"/>
                            
                            <Label text="City"/>
                            <Input value="{headerModel>/City}" editable="false"/>
                            
                            <Label text="Postal Code"/>
                            <Input value="{headerModel>/ZipCode}" editable="false"/>

                            <core:Title />
                            <Label text="No of Packages"/>
                            <Input value="{headerModel>/NoOfPackages}"/>
                            
                            <Label text="Exp. Return date"/>
                            <DatePicker value="{headerModel>/ExpReturnDate}" displayFormat="dd.MM.yyyy"/>
                            
                            <Label text="Category"/>
                            <Input value="{headerModel>/Category}" editable="false"/>
                            
                            <Label text="Gatepass Type"/>
                            <Input value="{headerModel>/Type}" editable="false"/>

                            <core:Title />
                            <Label text="Department"/>
                            <Input value="{headerModel>/Department}"/>
                            
                            <Label text="Requester Emp ID"/>
                            <Input value="{headerModel>/RequesterEmpID}"/>
                            
                            <Label text="HOD Emp ID"/>
                            <Input value="{headerModel>/HODEmpID}"/>
                            
                            <Label text="Store HOD Emp ID"/>
                            <Input value="{headerModel>/StoreHODEmpID}"/>
                        </f:content>
                    </f:SimpleForm>
                </Panel>

                <Table id="idItemsTable" items="{itemModel>/items}" headerText="Items">
                    <columns>
                        <Column><Text text="Status"/></Column>
                        <Column><Text text="Item"/></Column>
                        <Column><Text text="Material"/></Column>
                        <Column><Text text="Material Description"/></Column>
                        <Column><Text text="Unit"/></Column>
                        <Column><Text text="Sent Quantity"/></Column>
                        <Column><Text text="Requested Qty"/></Column>
                        <Column><Text text="Unit Price"/></Column>
                        <Column><Text text="Total Value"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <core:Icon src="sap-icon://status-completed" color="green"/>
                                <Text text="{itemModel>ItemNo}"/>
                                <Input value="{itemModel>Material}"/>
                                <Input value="{itemModel>Description}"/>
                                <Text text="{itemModel>UOM}"/>
                                <Input value="{itemModel>SentQuantity}" change="onQtyChange"/>
                                <Input value="{itemModel>RequestedQuantity}"/>
                                <Input value="{itemModel>UnitPrice}" change="onQtyChange"/>
                                <Text text="{itemModel>TotalValue}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

                <Panel headerText="gate">
                    <f:SimpleForm editable="true" layout="ColumnLayout">
                        <f:content>
                            <Label text="Remarks"/>
                            <Input value="{headerModel>/Remarks}"/>
                            
                            <Label text="Mode of Dispatch"/>
                            <Input value="{headerModel>/ModeOfDispatch}"/>
                            
                            <Label text="Vehicle No"/>
                            <Input value="{headerModel>/VehicleNo}"/>
                        </f:content>
                    </f:SimpleForm>
                </Panel>

                <HBox justifyContent="Center" class="sapUiSmallMargin">
                    <Button text="Save" type="Emphasized" press="onSave" width="200px"/>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
