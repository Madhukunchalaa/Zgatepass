<mvc:View controllerName="zgpms.meilpower.com.controller.OutGatePassDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout">

    <Page title="Out Gate Pass Cockpit">
        <headerContent>
            <Button icon="sap-icon://print" text="Print" type="Transparent" press="onPrint" />
        </headerContent>
        <content>

            <!-- ✅ Gate Pass Number Banner — visible ONLY after Save -->
            <MessageStrip
                id="gpNumberBanner"
                text="Gate Pass Number Generated: {detailModel>/GatePassNo}"
                type="Success"
                showIcon="true"
                visible="{= !!${detailModel>/GatePassNo} }"
                class="sapUiSmallMargin" />

            <!-- Header Section -->
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" title="Gate pass"
                labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0"
                columnsL="3" columnsM="2">
                <f:content>
                    <core:Title text="General" />
                    <Label text="Gate Pass Number" />
                    <Text text="{detailModel>/GatePassNo}" design="Bold" />
                    <Label text="Supplier" />
                    <Text text="{detailModel>/Vendor}" />
                    <Label text="Vendor Name" />
                    <Text text="{detailModel>/VendorName}" />
                    <Label text="Street and House No" />
                    <Text text="{detailModel>/Street}" />
                    <Label text="City" />
                    <Text text="{detailModel>/City}" />
                    <Label text="Postal Code" />
                    <Text text="{detailModel>/ZipCode}" />

                    <core:Title text="Reference" />
                    <Label text="Gate pass Date" />
                    <Text text="{path: 'detailModel>/Date', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}" />
                    <Label text="Purchasing Doc" />
                    <Input value="{detailModel>/PurchasingDoc}" editable="{detailModel>/editMode}" />
                    <Label text="Challan Date" />
                    <DatePicker value="{detailModel>/ChallanDate}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" editable="{detailModel>/editMode}" />
                    <Label text="Gate Entry No" />
                    <Input value="{detailModel>/GateEntryNo}" editable="{detailModel>/editMode}" />
                    <Label text="Gatepass Request Number" />
                    <Text text="{detailModel>/GatePassReqNo}" />

                    <core:Title text="Classification" />
                    <Label text="Department" />
                    <Text text="{detailModel>/Department}" />
                    <Label text="No of Packages" />
                    <Text text="{detailModel>/NoOfPackages}" />
                    <Label text="Delvry note/ Chlln No." />
                    <Input value="{detailModel>/DeliveryNote}" editable="{detailModel>/editMode}" />
                    <Label text="Gate pass typ" />
                    <Text text="{detailModel>/GatePassType}" />
                    <Label text="SPC Asset release number" />
                    <Text text="{detailModel>/SPCAssetNo}" />
                </f:content>
            </f:SimpleForm>

            <!-- Items Table -->
            <Table items="{detailModel>/GateReqItmNav/results}" class="sapUiMediumMarginTop">
                <columns>
                    <Column width="50px"><Text text="Status" /></Column>
                    <Column width="80px"><Text text="Item" /></Column>
                    <Column><Text text="Material" /></Column>
                    <Column minWidth="200px"><Text text="Material Description" /></Column>
                    <Column><Text text="UOM" /></Column>
                    <Column><Text text="Sent Quantity" /></Column>
                    <Column><Text text="Unit Price" /></Column>
                    <Column><Text text="Total Value" /></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <core:Icon src="sap-icon://status-completed" color="Positive" />
                            <Text text="{detailModel>ItemNo}" />
                            <Text text="{detailModel>Material}" />
                            <Text text="{detailModel>Description}" />
                            <Text text="{detailModel>UOM}" />
                            <Text text="{detailModel>SentQuantity}" />
                            <Input value="{detailModel>ItemNetPrice}" liveChange=".onPriceChange" />
                            <Text text="{detailModel>Totalvalue}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

            <!-- Gate Section -->
            <Panel headerText="gate" class="sapUiMediumMarginTop">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                    <f:content>
                        <Label text="Remarks" />
                        <TextArea value="{detailModel>/Remarks}" width="100%" rows="2" editable="{detailModel>/editMode}" />
                        <Label text="Mode of Despatch" />
                        <Input value="{detailModel>/ModeOfDispatch}" editable="{detailModel>/editMode}" />
                        <Label text="Vehicle No" />
                        <Input value="{detailModel>/VehicleNo}" editable="{detailModel>/editMode}" />
                    </f:content>
                </f:SimpleForm>
            </Panel>

            <HBox justifyContent="Center" class="sapUiMediumMarginTop">
                <Button text="Save" type="Emphasized" press="onSave" class="sapUiSmallMarginEnd" width="150px" visible="{detailModel>/editMode}" />
                <Button text="Print" press="onPrint" width="150px" />
            </HBox>
        </content>
    </Page>
</mvc:View>
