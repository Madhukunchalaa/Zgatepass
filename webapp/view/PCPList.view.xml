<mvc:View
	controllerName="zgpms.meilpower.com.controller.PCPList"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:f="sap.f"
	xmlns:core="sap.ui.core"
	height="100%">
	<Page title="Gate Entry List" class="gpmsPage" showNavButton="true" navButtonPress=".onNavBack">
		<content>
			<VBox class="sapUiSmallMargin">
				<Table id="pcpTable" items="{pcpList>/results}" class="gpmsTable" noDataText="No Gate Entries Found" alternateRowColors="true">
					<headerToolbar>
						<OverflowToolbar>
							<Title text="Gate Entry List" level="H2"/>
							<ToolbarSpacer />
							<SearchField width="300px" search=".onSearch" placeholder="Search..." class="gpmsFieldInput"/>
							<Button icon="sap-icon://sort" tooltip="Sort" press=".onSort" type="Transparent"/>
							<Button icon="sap-icon://filter" tooltip="Filter" press=".onFilter" type="Transparent"/>
							<Button text="Create Entry" icon="sap-icon://add" type="Emphasized" press=".onAddPCP" />
						</OverflowToolbar>
					</headerToolbar>
					<columns>
						<Column><Text text="GE Date" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="GE No" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="Supplier" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="Source Type" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="Desc" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="Dept" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="RGP No" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="Inv No" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="RR No" class="gpmsTableHeaderText"/></Column>
						<Column><Text text="Inspection Status" class="gpmsTableHeaderText"/></Column>
						<Column hAlign="Center"><Text text="Action" class="gpmsTableHeaderText"/></Column>
					</columns>
					<items>
						<ColumnListItem class="gpmsTableRow">
							<cells>
								<Text text="{pcpList>GEDate}" class="gpmsTableText"/>
								<Text text="{pcpList>GateEntryNo}" class="gpmsTableText"/>
								<Text text="{pcpList>VendorDesc}" class="gpmsTableText"/>
								<Text text="{pcpList>SourceType}" class="gpmsTableText"/>
								<Text text="{pcpList>FirstItemDesc}" class="gpmsTableText"/>
								<Text text="{pcpList>Department}" class="gpmsTableText"/>
								<Text text="{pcpList>RGPNumber}" class="gpmsTableText"/>
								<Text text="{pcpList>DCNumber}" class="gpmsTableText"/>
								<Text text="{pcpList>RRNo}" class="gpmsTableText"/>
								<Text text="{pcpList>InspectionStatus}" class="gpmsTableText"/>
								<HBox justifyContent="Center" class="gpmsActionBox">
									<Button icon="sap-icon://show" type="Default" tooltip="View" press=".onViewPCP" class="sapUiTinyMarginEnd gpmsActionButton"/>
									<Button icon="sap-icon://edit" type="Default" tooltip="Edit" press=".onEditPCP" class="sapUiTinyMarginEnd gpmsActionButton"/>
								</HBox>
							</cells>
						</ColumnListItem>
					</items>
				</Table>
			</VBox>
		</content>
	</Page>
</mvc:View>
