<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog title="Add Remarks">
        <content>
            <TextArea 
                value="{localModel>/Remarks}" 
                placeholder="Enter remarks here..." 
                rows="6" 
                width="100%" />
        </content>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onSaveRemarks" />
        </beginButton>
        <endButton>
            <Button text="Close" press="onCancelRemarks" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
