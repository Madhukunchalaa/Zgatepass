<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<TableSelectDialog
		id="scrapRequestValueHelpDialog"
		title="Select Approved Scrap Request"
		noDataText="No Approved Scrap Requests Found"
		search=".onScrapRequestValueHelpSearch"
		confirm=".onScrapRequestValueHelpConfirm"
		cancel=".onScrapRequestValueHelpCancel"
		items="{path: 'requests>/results'}">
		<columns>
			<Column width="25%">
				<header>
					<Text text="Request Number" />
				</header>
			</Column>
			<Column width="20%">
				<header>
					<Text text="Sale Order" />
				</header>
			</Column>
			<Column width="25%">
				<header>
					<Text text="Buyer/Vendor" />
				</header>
			</Column>
			<Column width="30%">
				<header>
					<Text text="Remarks / Description" />
				</header>
			</Column>
		</columns>
		<items>
			<ColumnListItem type="Active">
				<cells>
					<Text text="{requests>requestId}" />
					<Text text="{requests>saleOrder}" />
					<Text text="{requests>vendorName}" />
					<Text text="{requests>remarks}" />
				</cells>
			</ColumnListItem>
		</items>
	</TableSelectDialog>
</core:FragmentDefinition>
