<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
	<TableSelectDialog
		id="poValueHelpDialog"
		title="Select Purchase Order"
		noDataText="No Purchase Orders Found"
		search=".onPOValueHelpSearch"
		confirm=".onPOValueHelpConfirm"
		cancel=".onPOValueHelpCancel"
		items="{path: 'pos>/results'}">
		<columns>
			<Column width="30%">
				<header>
					<Text text="PO Number" />
				</header>
			</Column>
			<Column width="30%">
				<header>
					<Text text="Vendor Code" />
				</header>
			</Column>
			<Column width="40%">
				<header>
					<Text text="Vendor Name" />
				</header>
			</Column>
		</columns>
		<items>
			<ColumnListItem type="Active">
				<cells>
					<Text text="{pos>PurchaseOrder}" />
					<Text text="{pos>Vendor}" />
					<Text text="{pos>VendorDesc}" />
				</cells>
			</ColumnListItem>
		</items>
	</TableSelectDialog>
</core:FragmentDefinition>
