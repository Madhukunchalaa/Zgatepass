<mvc:View controllerName="zgpms.meilpower.com.controller.GatePassExitDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout">

    <Page title="Gate Pass Exit Details">
        <content>
            <!-- Header Section -->
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" title="Gate pass"
                labelSpanL="4" labelSpanM="4" emptySpanL="0" emptySpanM="0"
                columnsL="3" columnsM="2">
                <f:content>
                    <core:Title text="General" />
                    <Label text="Gate Pass No" />
                    <Text text="{exitDetailModel>/GatePassNo}" />
                    <Label text="Supplier" />
                    <Text text="{exitDetailModel>/Vendor}" />
                    <Label text="Vendor Name" />
                    <Text text="{exitDetailModel>/VendorName}" />
                    <Label text="Street and House No" />
                    <Text text="{exitDetailModel>/Street}" />
                    <Label text="City" />
                    <Text text="{exitDetailModel>/City}" />
                    <Label text="Postal Code" />
                    <Text text="{exitDetailModel>/ZipCode}" />

                    <core:Title text="Reference" />
                    <Label text="Gate pass Date" />
                    <Text text="{path: 'exitDetailModel>/Date', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}" />
                    <Label text="Purchasing Doc" />
                    <Input value="{exitDetailModel>/PurchasingDoc}" />
                    <Label text="Challan Date" />
                    <Text text="{exitDetailModel>/ChallanDate}" />
                    <Label text="Gate Entry No" />
                    <Input value="{exitDetailModel>/GateEntryNo}" />
                    <Label text="Exp. Return date" />
                    <Text text="{path: 'exitDetailModel>/ReturnDate', type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd.MM.yyyy'}}" />

                    <core:Title text="Classification" />
                    <Label text="Department" />
                    <Text text="{exitDetailModel>/Department}" />
                    <Label text="No of Packages" />
                    <Text text="{exitDetailModel>/NoOfPackages}" />
                    <Label text="Delvry note/ Chlln No." />
                    <Input value="{exitDetailModel>/DeliveryNote}" />
                    <Label text="Material exit Allowed" />
                    <ComboBox selectedKey="{exitDetailModel>/ExitAllowed}">
                        <core:Item key="YES" text="Yes" />
                        <core:Item key="NO" text="No" />
                    </ComboBox>
                    <Label text="Gate pass type" />
                    <Text text="{exitDetailModel>/GatePassType}" />
                </f:content>
            </f:SimpleForm>

            <!-- Items Table -->
            <Table items="{exitDetailModel>/GateReqItmNav/results}" class="sapUiMediumMarginTop">
                <columns>
                    <Column width="50px"><Text text="Status" /></Column>
                    <Column width="80px"><Text text="Item" /></Column>
                    <Column><Text text="Material" /></Column>
                    <Column minWidth="200px"><Text text="Material Description" /></Column>
                    <Column><Text text="UOM" /></Column>
                    <Column><Text text="Sent Quantity" /></Column>
                    <Column><Text text="Unit Price" /></Column>
                    <Column><Text text="Receiving Quantity" /></Column>
                    <Column><Text text="Total Value" /></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <core:Icon src="sap-icon://status-completed" color="Positive" />
                            <Text text="{exitDetailModel>ItemNo}" />
                            <Text text="{exitDetailModel>Material}" />
                            <Text text="{exitDetailModel>Description}" />
                            <Text text="{exitDetailModel>UOM}" />
                            <Text text="{exitDetailModel>SentQuantity}" />
                            <Text text="{exitDetailModel>ItemNetPrice}" />
                            <Text text="{exitDetailModel>RecievedQuantity}" />
                            <Text text="{exitDetailModel>Totalvalue}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

            <!-- Gate Section -->
            <Panel headerText="gate" class="sapUiMediumMarginTop">
                <f:SimpleForm editable="true" layout="ResponsiveGridLayout">
                    <f:content>
                        <Label text="Remarks" />
                        <TextArea value="{exitDetailModel>/Remarks}" width="100%" rows="2" />
                        <Label text="Mode of Dispatch" />
                        <Input value="{exitDetailModel>/ModeOfDispatch}" />
                        <Label text="Vehicle No" />
                        <Input value="{exitDetailModel>/VehicleNo}" />
                    </f:content>
                </f:SimpleForm>
            </Panel>

            <HBox justifyContent="Center" class="sapUiMediumMarginTop sapUiLargeMarginBottom">
                <Button text="Save" type="Emphasized" press="onSaveExit" width="150px" />
            </HBox>
        </content>
    </Page>
</mvc:View>
