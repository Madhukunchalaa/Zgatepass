<mvc:View
	controllerName="zgpms.meilpower.com.controller.HODRequestDetail"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	height="100%">

	<Page id="hodRequestDetailPage" title="Gate Pass Request Detail"
		showNavButton="true" navButtonPress=".onNavBack" class="gpmsPage">

		<content>
			<VBox class="gpmsContentWrapper sapUiMediumMargin">

				<!-- Status Banner -->
				<MessageStrip
					text="{= 'Request No: ' + ${hod>/GatePassReqNo} + '  |  Status: ' + ${hod>/Status}}"
					type="{= ${hod>/Status} === 'Approved' ? 'Success' : (${hod>/Status} === 'Rejected' || ${hod>/Status} === 'Cancelled') ? 'Error' : 'Warning'}"
					showIcon="true" class="sapUiSmallMarginBottom"/>

				<!-- Request Details Panel -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<core:Icon src="sap-icon://document-text" class="gpmsSectionBarIcon"/>
							<Label text="Request Details" class="gpmsSectionBarLabel"/>
							<ToolbarSpacer/>
							<ObjectStatus text="{hod>/GatePassType}" state="Information" icon="sap-icon://tag"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL3 L3 M6 S12" vSpacing="0">
						<VBox class="sapUiSmallMargin">
							<Label text="Request No." class="gpmsFieldLabel"/>
							<Input value="{hod>/GatePassReqNo}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Gate Pass Type" class="gpmsFieldLabel"/>
							<Input value="{hod>/GatePassType}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Request Date" class="gpmsFieldLabel"/>
							<Input value="{hod>/GpDate}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Plant" class="gpmsFieldLabel"/>
							<Input value="{hod>/Plant}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Department" class="gpmsFieldLabel"/>
							<Input value="{hod>/Department}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor Name" class="gpmsFieldLabel"/>
							<Input value="{hod>/VendorName}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="Vendor GST" class="gpmsFieldLabel"/>
							<Input value="{hod>/VendorGST}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin">
							<Label text="City / Address" class="gpmsFieldLabel"/>
							<Input value="{hod>/VendorAddress}" editable="false" class="gpmsFieldInput"/>
						</VBox>
						<VBox class="sapUiSmallMargin" visible="{= ${hod>/GatePassType} === 'RGP' }">
							<Label text="Due Date" class="gpmsFieldLabel"/>
							<Input value="{hod>/ReturnableDate}" editable="false" class="gpmsFieldInput"/>
						</VBox>
					</layout:Grid>
				</Panel>

				<!-- Attachment Panel — shown only when a file was uploaded -->
				<Panel class="gpmsSection" expandable="false" visible="{hod>/hasAttachment}">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<core:Icon src="sap-icon://attachment" class="gpmsSectionBarIcon"/>
							<Label text="Gate Pass Attachments" class="gpmsSectionBarLabel"/>
						</Toolbar>
					</headerToolbar>
					<FlexBox class="sapUiSmallMargin" wrap="Wrap" justifyContent="SpaceAround" alignItems="Center" width="100%">
						<!-- Attachment 1 Block -->
						<VBox class="sapUiMediumMarginEnd sapUiSmallMarginBottom gpmsAttachmentPreviewBox" alignItems="Center" visible="{hod>/hasAttachment1}" width="280px">
							<Label text="Attachment 1" class="gpmsBoldText sapUiSmallMarginBottom"/>
							<!-- Image Preview -->
							<VBox alignItems="Center" visible="{hod>/isImage1}">
								<Image src="{hod>/Base64Img1}" press=".onImagePress" activeSrc="{hod>/Base64Img1}" width="220px" class="sapUiSmallMarginBottom gpmsAttachmentThumbnail"/>
							</VBox>
							<!-- Non-Image File Icon -->
							<VBox alignItems="Center" visible="{= !${hod>/isImage1} }">
								<core:Icon src="{= ${hod>/isPdf1} ? 'sap-icon://pdf-attachment' : 'sap-icon://doc-attachment' }" size="4rem" color="#1A237E" class="sapUiMediumMarginBottom"/>
								<Text text="{hod>/Fname}" class="gpmsBoldText sapUiSmallMarginBottom" maxLines="1"/>
							</VBox>
							<!-- Action Button -->
							<Button text="{= ${hod>/isPdf1} ? 'Open PDF 1' : 'Download File 1' }" icon="{= ${hod>/isPdf1} ? 'sap-icon://pdf-attachment' : 'sap-icon://download' }" press=".onDownloadAttachment1" type="Emphasized" class="sapUiSmallMarginTop"/>
						</VBox>

						<!-- Attachment 2 Block -->
						<VBox class="sapUiSmallMarginBottom gpmsAttachmentPreviewBox" alignItems="Center" visible="{hod>/hasAttachment2}" width="280px">
							<Label text="Attachment 2" class="gpmsBoldText sapUiSmallMarginBottom"/>
							<!-- Image Preview -->
							<VBox alignItems="Center" visible="{hod>/isImage2}">
								<Image src="{hod>/Base64Img2}" press=".onImagePress" activeSrc="{hod>/Base64Img2}" width="220px" class="sapUiSmallMarginBottom gpmsAttachmentThumbnail"/>
							</VBox>
							<!-- Non-Image File Icon -->
							<VBox alignItems="Center" visible="{= !${hod>/isImage2} }">
								<core:Icon src="{= ${hod>/isPdf2} ? 'sap-icon://pdf-attachment' : 'sap-icon://doc-attachment' }" size="4rem" color="#1A237E" class="sapUiMediumMarginBottom"/>
								<Text text="{hod>/Fname2}" class="gpmsBoldText sapUiSmallMarginBottom" maxLines="1"/>
							</VBox>
							<!-- Action Button -->
							<Button text="{= ${hod>/isPdf2} ? 'Open PDF 2' : 'Download File 2' }" icon="{= ${hod>/isPdf2} ? 'sap-icon://pdf-attachment' : 'sap-icon://download' }" press=".onDownloadAttachment2" type="Emphasized" class="sapUiSmallMarginTop"/>
						</VBox>
					</FlexBox>
				</Panel>

				<!-- Items Table -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<core:Icon src="sap-icon://grid" class="gpmsSectionBarIcon"/>
							<Label text="Table of Items" class="gpmsSectionBarLabel"/>
						</Toolbar>
					</headerToolbar>
					<Table items="{hod>/items}" noDataText="No items found." class="gpmsItemTable" alternateRowColors="true">
						<columns>
							<Column width="3rem" hAlign="Center"><Text text="#" class="gpmsHeaderText"/></Column>
							<Column><Text text="Material Description" class="gpmsHeaderText"/></Column>
							<Column width="8rem"><Text text="HSN Code" class="gpmsHeaderText"/></Column>
							<Column width="5rem" hAlign="Center"><Text text="UOM" class="gpmsHeaderText"/></Column>
							<Column width="9rem" hAlign="Right"><Text text="Quantity" class="gpmsHeaderText"/></Column>
							<Column width="9rem" hAlign="Right"><Text text="Rate (Rs.)" class="gpmsHeaderText"/></Column>
							<Column width="10rem" hAlign="Right"><Text text="Amount (Rs.)" class="gpmsHeaderText"/></Column>
						</columns>
						<items>
							<ColumnListItem>
								<cells>
									<Text text="{hod>sno}"/>
									<Text text="{hod>materialName}" wrapping="true"/>
									<Text text="{hod>hsnCode}"/>
									<Text text="{hod>uom}" textAlign="Center"/>
									<Text text="{path: 'hod>quantity', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 3, maxFractionDigits: 3}}" textAlign="Right"/>
									<Text text="{path: 'hod>rate', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 2, maxFractionDigits: 2}}" textAlign="Right"/>
									<Text text="{path: 'hod>amount', type: 'sap.ui.model.type.Float', formatOptions: {minFractionDigits: 2, maxFractionDigits: 2}}" textAlign="Right" class="gpmsBoldText"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
					<HBox justifyContent="End" class="sapUiSmallMarginTop sapUiSmallMarginEnd sapUiSmallMarginBottom">
						<VBox alignItems="End">
							<Label text="TOTAL AMOUNT (RS.)" class="gpmsTotalLabel"/>
							<Text text="{hod>/totalAmount}" class="gpmsTotalAmount"/>
						</VBox>
					</HBox>
				</Panel>

				<!-- HOD Decision Panel -->
				<Panel class="gpmsSection" expandable="false">
					<headerToolbar>
						<Toolbar class="gpmsSectionBar">
							<core:Icon src="sap-icon://approvals" class="gpmsSectionBarIcon"/>
							<Label text="Decision &amp; Remarks" class="gpmsSectionBarLabel"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL6 L6 M12 S12" vSpacing="0" hSpacing="0.5">
						<!-- Requester Remarks (Read-Only) -->
						<VBox class="sapUiSmallMargin">
							<Label text="Requester Remarks" class="gpmsFieldLabel"/>
							<TextArea
								value="{hod>/Remarks}"
								editable="false"
								rows="5"
								width="100%"
								class="gpmsFieldInput gpmsFieldInputReadonly gpmsTextAreaBig"/>
						</VBox>
						<!-- HOD Remarks (Editable) -->
						<VBox class="sapUiSmallMargin">
							<Label text="HOD Remarks" class="gpmsFieldLabel"/>
							<TextArea
								value="{hod>/HODRemarks}"
								placeholder="Enter your remarks here before approving / rejecting / sending for amendment (up to 250 characters)..."
								rows="5"
								width="100%"
								maxLength="250"
								showExceededText="true"
								class="gpmsFieldInput gpmsTextAreaBig"/>
						</VBox>
					</layout:Grid>
				</Panel>

			</VBox>
		</content>

		<footer>
			<OverflowToolbar class="gpmsFooterBar">
				<Button text="Approve" type="Accept" icon="sap-icon://accept" press=".onApprove"
					visible="{= ${hod>/Status} === 'Pending'}" class="sapUiSmallMarginBegin"/>
				<Button text="Reject" type="Reject" icon="sap-icon://decline" press=".onReject"
					visible="{= ${hod>/Status} === 'Pending'}"/>
				<Button text="Amendment" type="Emphasized" icon="sap-icon://edit" press=".onAmend"
					visible="{= ${hod>/Status} === 'Pending'}"/>
				<ToolbarSpacer/>
				<Button text="Back" icon="sap-icon://nav-back" press=".onNavBack"/>
			</OverflowToolbar>
		</footer>

	</Page>
</mvc:View>
