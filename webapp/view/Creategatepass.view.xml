<mvc:View
	controllerName="zgpms.meilpower.com.controller.Creategatepass"
	xmlns="sap.m"
	xmlns:l="sap.ui.layout"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core"
	xmlns:mvc="sap.ui.core.mvc">



	<Page showHeader="false">
		<landmarkInfo>
			<PageAccessibleLandmarkInfo
				rootRole="Region"
				rootLabel="{i18n>Creategatepass_rootLabel}"
				contentRole="Main"
				contentLabel="{i18n>Creategatepass_contentLabel}"/>
		</landmarkInfo>
		<content>
			<Panel
				id="CreategatepassContainer"
				accessibleRole="Region"
				class="sapUiNoContentPadding">
				<headerToolbar>
					<Toolbar>
						<Title
							text="Meil Power"
							level="H3"
							textAlign="Left"/>
						<ToolbarSpacer/>
						
					</Toolbar>
				</headerToolbar>
		
					<!-- Form starts here -->
					<VBox class="sapUiSmallMargin">
		<f:Form id="FormChangeColumn_threeGroups234"
			editable="true">
			<f:title>
				<core:Title text="Create GatePass" />
			</f:title>
			<f:layout>
				<f:ColumnLayout
					columnsM="2"
					columnsL="3"
					columnsXL="4"
				/>
			</f:layout>
			<f:formContainers>
				<f:FormContainer title="">
				<f:FormElement label="GatePass For">
							<f:fields>
								<Select id="gatepassfor" selectedKey="{gfor}">
									<items>
										<core:Item text="Coal" key="coal"/>
										<core:Item text="lignite" key="lignite"/>
										<core:Item text="Ash" key="Ash"/>
										<core:Item text="With PO" key="WPO"/>
										<core:Item text="Without PO" key="WTPO"/>
										<core:Item text="Scrap Gatepass" key="SCGP"/>
										<core:Item text="PCP - CashPurchase" key="PCP-Cash"/>
										<core:Item text="Empty Vehicle In" key="VHIN"/>

									</items>
								</Select>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="GatePass Type">
							<f:fields>
								<Select id="gatepasstype" selectedKey="{gtype}">
									<items>
										<core:Item text="Returnable" key="rgp"/>
										<core:Item text="Non Retunable" key="nrgp"/>
								</items>
								</Select>
							</f:fields>
						</f:FormElement>


							<f:FormElement label="Material Transfer">
							<f:fields>
								<Select id="gatepassopt" selectedKey="{gtype}">
									<items>
										<core:Item text="Internal" key="rgp"/>
										<core:Item text="External" key="nrgp"/>
								</items>
								</Select>
							</f:fields>
						</f:FormElement>

					<f:formElements>
						<f:FormElement label="Plant">
							<f:fields>
								<ComboBox id="idPlantsComboBox"
									selectedKey="{form>/Plant}"
									items="{path: 'plantModel>/plants'}">
									<core:Item key="{plantModel>Plant}" text="{plantModel>Plant} - {plantModel>PlantName}"/>
								</ComboBox>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="Vendor">
							<f:fields>
								<Select id="vendorid" selectedKey="{form>/Vendor}"
									items="{path: 'vendor>/vendors', templateShareable: false}"
									change="onVendorChange">
									<core:Item key="{vendor>Vendor}" text="{vendor>Name}" />
								</Select>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="Vendor Address">
							<f:fields>
								<TextArea id="vendoraddr" value="{form>/VendorAddress}" editable="false" rows="2" width="100%"/>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="ZIP Code/City">
							<f:fields>
								<Input value="{form>/ZIPCode}" editable="false">
									<layoutData>
										<f:ColumnElementData cellsSmall="3" cellsLarge="2" />
									</layoutData>
								</Input>
								<Input value="{form>/City}" editable="false"/>
							</f:fields>
						</f:FormElement>
						
						
					</f:formElements>
				</f:FormContainer>
				<f:FormContainer title="">
					<f:formElements>
						<f:FormElement label="Approval Required">
							<f:fields>
								<Select id="approvalrequired" selectedKey="{form>/ApprovalReq}">
									<items>
										<core:Item text="Yes" key="Y"/>
										<core:Item text="No" key="N"/>
									</items>
								</Select>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="Department">
							<f:fields>
								<Input value="{form>/Department}" id="department"/>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="Creation Date">
							<f:fields>
								<DatePicker value="{form>/CreationDate}"
									valueFormat="yyyy-MM-dd"
									displayFormat="dd/MM/yyyy"
									editable="false"/>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="Returnable Date">
							<f:fields>
								<DatePicker value="{form>/ReturnableDate}"
									valueFormat="yyyy-MM-dd"
									displayFormat="dd/MM/yyyy"/>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="Vehicle Number">
							<f:fields>
								<Input value="{form>/VehicleNo}" id="VehicleNumber"/>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="Mode of Dispatch">
							<f:fields>
								<Input value="{form>/ModeOfDispatch}" id="modeofdispatch"/>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="Remarks">
							<f:fields>
								<TextArea id="remarks" value="{form>/Remarks}" rows="3" width="100%"/>
							</f:fields>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>

				<!-- Employee & Packages -->
				<f:FormContainer title="Employee &amp; Approval Details">
					<f:formElements>
						<f:FormElement label="Requestor Employee ID" >
							<f:fields>
								<Input value="{form>/ReqEmpID}" placeholder="e.g. 80001234"/>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="HOD Employee ID">
							<f:fields>
								<Input value="{form>/HODEmpID}" placeholder="e.g. 80005678"/>
							</f:fields>
						</f:FormElement>

						<f:FormElement label="No. of Packages">
							<f:fields>
								<Input value="{form>/NoOfPackages}" type="Number"/>
							</f:fields>
						</f:FormElement>
					</f:formElements>
				</f:FormContainer>

			</f:formContainers>
		</f:Form>
	</VBox>

						<!-- Form Ends  here -->
<!-- Table Starts here -->
						<VBox>
<Table id="tableId" width="90%" mode='Delete' delete="deleteRow">
<headerToolbar>
<Toolbar>
<ToolbarSpacer></ToolbarSpacer>
<Button icon="sap-icon://add" type="Emphasized" press="onAdd" />
</Toolbar>
</headerToolbar>
<columns>
<Column width="50%">
<Text text="sno" />
</Column>
<Column width="50%">
<Text text="Item" />
</Column>
<Column width="50%">
<Text text="Material" />
</Column>
<Column width="50%">
<Text text="Description" />
</Column>
<Column width="50%">
<Text text="Uom" />
</Column>
<Column width="50%">
<Text text="Unit Price" />
</Column>
<Column width="50%">
<Text text="Actual Qty" />
</Column>
<Column width="50%">
<Text text="Received Qty" />
</Column>
<Column width="50%">
<Text text="Total Value" />
</Column>

<Column width="50%">
<Text text="Delete" />
</Column>
</columns>
</Table>
						
						</VBox>

<!-- Table Ends here -->


	</Panel>

		</content>
			<footer>
			<OverflowToolbar id="otbFooter">
				<ToolbarSpacer/>
				<Button type="Emphasized" text="Save" press="onSave">
					<layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
				</Button>
				<Button type="Emphasized" text="Reset" press="onReset">
					<layoutData><OverflowToolbarLayoutData priority="NeverOverflow" /></layoutData>
				</Button>
				
			</OverflowToolbar>
		</footer>
	</Page>
</mvc:View>