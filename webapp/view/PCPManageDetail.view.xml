<mvc:View
	controllerName="zgpms.meilpower.com.controller.PCPManageDetail"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:layout="sap.ui.layout"
	xmlns:core="sap.ui.core"
	height="100%">

	<Page id="idPCPPage" title="{pcpDetail>/pageTitle}" class="sapUiContentPadding gpmsPage"
		showNavButton="true" navButtonPress=".onNavBack">

		<content>
			<VBox class="gpmsMainContainer">

				<!-- Form Panel -->
				<Panel expandable="true" expanded="true" class="gpmsPanel sapUiSmallMarginBottom">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://header" class="sapUiSmallMarginEnd"/>
							<Title text="GATE ENTRY DETAILS" level="H3"/>
						</Toolbar>
					</headerToolbar>
					<layout:Grid defaultSpan="XL4 L4 M6 S12" vSpacing="1">

						<!-- Row 1: GE Date | GE No | Entry Point -->
						<VBox class="sapUiSmallMargin">
							<Label text="GE Date" required="true" class="gpmsFieldLabel"/>
							<DatePicker id="idPCPGEDate"
								value="{pcpDetail>/GEDate}"
								displayFormat="dd-MM-yyyy"
								valueFormat="yyyy-MM-dd"
								width="100%" class="gpmsFieldInput"
								enabled="{pcpDetail>/editable}"
								change=".onGEDateChange"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="GE No" required="true" class="gpmsFieldLabel"/>
							<Input id="idGENo"
								value="{pcpDetail>/GateEntryNo}"
								placeholder="Enter GE No"
								width="100%" class="gpmsFieldInput"
								enabled="{pcpDetail>/editable}"
								change=".onGENoChange"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="Entry Point" required="true" class="gpmsFieldLabel"/>
							<Select id="idEntryPoint"
								selectedKey="{pcpDetail>/EntryPoint}"
								width="100%"
								enabled="{pcpDetail>/editable}"
								class="gpmsFieldInput">
								<items>
									<core:Item key="" text="Select Entry Point"/>
									<core:Item key="PLANT" text="PLANT"/>
									<core:Item key="OTHERS" text="OTHERS"/>
								</items>
							</Select>
						</VBox>

						<!-- Row 2: PCP Date | Supplier | Department -->
						<VBox class="sapUiSmallMargin">
							<Label text="PCP Date" required="true" class="gpmsFieldLabel"/>
							<DatePicker id="idPCPDate"
								value="{pcpDetail>/PCPDate}"
								displayFormat="dd-MM-yyyy"
								valueFormat="yyyy-MM-dd"
								width="100%" class="gpmsFieldInput"
								enabled="{pcpDetail>/editable}"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="Supplier" class="gpmsFieldLabel"/>
							<Input id="idSupplier"
								value="{pcpDetail>/VendorDesc}"
								placeholder="Supplier name"
								width="100%" class="gpmsFieldInput"
								enabled="{pcpDetail>/editable}"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="Department" required="true" class="gpmsFieldLabel"/>
							<Input id="idDept"
								value="{pcpDetail>/Department}"
								placeholder="Enter Department"
								width="100%" class="gpmsFieldInput"
								enabled="{pcpDetail>/editable}"/>
						</VBox>

						<!-- Row 3: DC / Invoice No | DC / Invoice Date | Budget Code -->
						<VBox class="sapUiSmallMargin">
							<Label text="DC / Invoice No" class="gpmsFieldLabel"/>
							<Input id="idDCNo"
								value="{pcpDetail>/DCNumber}"
								placeholder="Enter DC or Invoice No"
								width="100%" class="gpmsFieldInput"
								enabled="{pcpDetail>/editable}"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="DC / Invoice Date" class="gpmsFieldLabel"/>
							<DatePicker id="idDCDate"
								value="{pcpDetail>/DCdate}"
								displayFormat="dd-MM-yyyy"
								valueFormat="yyyy-MM-dd"
								width="100%" class="gpmsFieldInput"
								enabled="{pcpDetail>/editable}"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="Budget Code" required="true" class="gpmsFieldLabel"/>
							<Input id="idPCPBudgetCode"
								value="{pcpDetail>/BudgetCode}"
								placeholder="CAPEX / OPEX / PETTY CASH"
								width="100%" class="gpmsFieldInput"
								enabled="{pcpDetail>/editable}"/>
						</VBox>

						<VBox class="sapUiSmallMargin">
							<Label text="Total Cost (in Rs)" required="true" class="gpmsFieldLabel"/>
							<Input id="idPCPTotalCost"
								value="{pcpDetail>/TotalCost}"
								type="Number"
								placeholder="Total Cost (in Rs)"
								width="100%" class="gpmsFieldInput"
								enabled="{pcpDetail>/editable}"/>
						</VBox>

					</layout:Grid>
				</Panel>

				<!-- Items Table -->
				<Panel expandable="true" expanded="true" class="gpmsPanel sapUiSmallMarginBottom">
					<headerToolbar>
						<Toolbar height="3rem">
							<core:Icon src="sap-icon://table-view" class="sapUiSmallMarginEnd"/>
							<Title text="LINE ITEMS" level="H3"/>
							<ToolbarSpacer/>
							<Button text="Add Row" icon="sap-icon://add" type="Emphasized" press=".onAddItem"
								visible="{pcpDetail>/editable}" class="sapUiTinyMarginEnd"/>
						</Toolbar>
					</headerToolbar>
					<Table items="{pcpDetail>/items}" class="gpmsItemTable" alternateRowColors="true">
						<columns>
							<Column width="3rem" hAlign="Center"><Text text="#" class="gpmsHeaderText"/></Column>
							<Column><Text text="Item Description" class="gpmsHeaderText"/></Column>
							<Column width="8rem" hAlign="Right"><Text text="Qty" class="gpmsHeaderText"/></Column>
							<Column width="7rem"><Text text="UOM" class="gpmsHeaderText"/></Column>
							<Column width="4rem" hAlign="Center" visible="{pcpDetail>/editable}"><Text text="" class="gpmsHeaderText"/></Column>
						</columns>
						<items>
							<ColumnListItem>
								<cells>
									<Text text="{pcpDetail>sno}"/>
									<Input value="{pcpDetail>ItemDescription}" placeholder="Item Description" class="gpmsTableInput" editable="{pcpDetail>/editable}"/>
									<Input value="{pcpDetail>RecievedQuantity}" type="Number" textAlign="Right" class="gpmsTableInput" editable="{pcpDetail>/editable}"/>
									<Select selectedKey="{pcpDetail>UOM}" class="gpmsTableInput" width="100%" enabled="{pcpDetail>/editable}" forceSelection="false">
										<items>
											<core:Item key="" text="Select UOM"/>
											<core:Item key="Number" text="Number"/>
											<core:Item key="Feet" text="Feet"/>
											<core:Item key="Kilogram" text="Kilogram"/>
											<core:Item key="Length" text="Length"/>
											<core:Item key="Litre" text="Litre"/>
											<core:Item key="Load" text="Load"/>
											<core:Item key="Lot" text="Lot"/>
											<core:Item key="Meters" text="Meters"/>
											<core:Item key="Metric Tons" text="Metric Tons"/>
											<core:Item key="Pair" text="Pair"/>
											<core:Item key="Roll" text="Roll"/>
											<core:Item key="Set" text="Set"/>
											<core:Item key="Sheet" text="Sheet"/>
											<core:Item key="Square Feet" text="Square Feet"/>
											<core:Item key="Square Meter" text="Square Meter"/>
											<core:Item key="Item" text="Item"/>
											<core:Item key="Pack" text="Pack"/>
											<core:Item key="Days" text="Days"/>
											<core:Item key="Pocket" text="Pocket"/>
											<core:Item key="Ream" text="Ream"/>
											<core:Item key="Tons" text="Tons"/>
											<core:Item key="Unit" text="Unit"/>
											<core:Item key="Month" text="Month"/>
										</items>
									</Select>
									<Button icon="sap-icon://delete" type="Transparent" press=".onDeleteItem" class="gpmsDeleteBtn" visible="{pcpDetail>/editable}"/>
								</cells>
							</ColumnListItem>
						</items>
					</Table>
				</Panel>

				<!-- Generated GP No banner -->
				<MessageStrip
					text="{= 'Gate Pass No generated: ' + ${pcpDetail>/GatepassNo}}"
					type="Success"
					showIcon="true"
					visible="{= !!${pcpDetail>/GatepassNo} }"
					class="sapUiSmallMarginBottom"/>

				<!-- Action Buttons -->
				<HBox justifyContent="End" class="sapUiMediumMarginTop">
					<Button id="idSubmitBtn"
						text="Submit"
						type="Accept"
						press=".onSubmit"
						icon="sap-icon://sys-add"
						visible="{pcpDetail>/editable}"
						class="gpmsSubmitBtn sapUiSmallMarginEnd"/>
					<Button id="idPrintBtn"
						text="Print"
						icon="sap-icon://print"
						type="Emphasized"
						press=".onPrint"
						visible="{= !!${pcpDetail>/GatepassNo} }"
						class="gpmsDocBtn sapUiSmallMarginEnd"/>
					<Button text="Back"
						type="Transparent"
						press=".onNavBack"
						icon="sap-icon://nav-back"/>
				</HBox>

			</VBox>
		</content>
	</Page>

</mvc:View>
