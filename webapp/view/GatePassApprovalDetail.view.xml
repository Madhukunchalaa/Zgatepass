<mvc:View controllerName="zgpms.meilpower.com.controller.GatePassApprovalDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns="sap.m"
    height="100%">

    <Page title="Gate Pass Request Approval" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <VBox class="sapUiSmallMargin">
                <!-- Header Info -->
                <Panel headerText="Gate pass request Approval">
                    <f:SimpleForm editable="true" layout="ColumnLayout" columnsM="2" columnsL="3">
                        <f:content>
                            <Label text="Gate Pass Req No"/>
                            <Input value="{headerModel>/GatePassReqNo}" editable="false"/>
                            
                            <Label text="Supplier"/>
                            <Input value="{headerModel>/Vendor}" editable="false"/>
                            
                            <Label text="Vendor Name"/>
                            <Input value="{headerModel>/VendorName}" editable="false"/>
                            
                            <Label text="Street and House No"/>
                            <Input value="{headerModel>/Street}" editable="false"/>
                            
                            <Label text="City"/>
                            <Input value="{headerModel>/City}" editable="false"/>
                            
                            <Label text="Postal Code"/>
                            <Input value="{headerModel>/ZipCode}" editable="false"/>

                            <core:Title />
                            <Label text="No of Packages"/>
                            <Input value="{headerModel>/NoOfPackages}" editable="false"/>
                            
                            <Label text="Exp. Return date"/>
                            <Input value="{headerModel>/ReturnableDate}" editable="false"/>
                            
                            <Label text="Accept/Reject"/>
                            <Select selectedKey="{headerModel>/Decision}">
                                <core:Item key="A" text="Acceptance"/>
                                <core:Item key="R" text="Rejection"/>
                            </Select>
                            
                            <Label text="Plant HOD Emp ID"/>
                            <Input value="{headerModel>/PlantHODId}" />

                            <core:Title />
                            <Label text="Department"/>
                            <Input value="{headerModel>/Department}" editable="false"/>
                            
                            <Label text="Requester Emp ID"/>
                            <Input value="{headerModel>/ReqEmpID}" editable="false"/>
                            
                            <Label text="HOD Emp ID"/>
                            <Input value="{headerModel>/HODEmpID}" editable="false"/>
                            
                            <Label text="Store HOD Emp ID"/>
                            <Input value="{headerModel>/StoreHODEmpID}" editable="false"/>
                            
                            <Label text="Finance HOD Emp ID"/>
                            <Input value="{headerModel>/FinanceHODId}" editable="false"/>
                            
                            <Label text="Remarks"/>
                            <Input value="{headerModel>/Remarks}"/>
                        </f:content>
                    </f:SimpleForm>
                </Panel>

                <!-- Items Table -->
                <Table items="{itemModel>/items}" headerText="Items">
                    <columns>
                        <Column width="50px"><Text text="Status"/></Column>
                        <Column width="80px"><Text text="Item"/></Column>
                        <Column><Text text="Material"/></Column>
                        <Column minWidth="200px"><Text text="Material Description"/></Column>
                        <Column width="80px"><Text text="Unit"/></Column>
                        <Column><Text text="Sent/Rec. Qty"/></Column>
                        <Column><Text text="Unit Price"/></Column>
                        <Column><Text text="Total Value"/></Column>
                        <Column><Text text="Sent Remarks"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <core:Icon src="sap-icon://status-completed" color="green"/>
                                <Text text="{itemModel>ItemNo}"/>
                                <Text text="{itemModel>Material}"/>
                                <Text text="{itemModel>Description}"/>
                                <Text text="{itemModel>UOM}"/>
                                <Text text="{itemModel>RequestedQuantity}"/>
                                <Text text="{itemModel>ItemNetPrice}"/>
                                <Text text="{itemModel>Totalvalue}"/>
                                <Input value="{itemModel>Remarks}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>

                <!-- Gate Section -->
                <Panel headerText="gate">
                    <f:SimpleForm editable="true" layout="ColumnLayout">
                        <f:content>
                            <Label text="Remarks"/>
                            <Input value="{headerModel>/GateRemarks}"/>
                            
                            <Label text="Mode of Dispatch"/>
                            <Input value="{headerModel>/ModeOfDispatch}"/>
                            
                            <Label text="Vehicle No"/>
                            <Input value="{headerModel>/VehicleNo}"/>
                        </f:content>
                    </f:SimpleForm>
                </Panel>

                <HBox justifyContent="Center" class="sapUiSmallMargin">
                    <Button text="Save" type="Emphasized" press="onSave" width="200px"/>
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
