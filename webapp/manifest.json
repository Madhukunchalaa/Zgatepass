{
	"_version": "1.21.0",
	"sap.app": {
		"id": "zgpms.meilpower.com",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"fallbackLocale": "en",
			"supportedLocales": ["en", "de"]
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"applicationVersion": {
			"version": "1.0.0"
		},
		"dataSources": {
			"mainService": {
				"uri": "/sap/opu/odata/sap/ZSEPC_GATEPASS_SRV/",
				"type": "OData",
				"settings": {
					"odataVersion": "2.0"
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		},
		"supportedThemes": [
			"sap_hcb",
			"sap_bluecrystal",
			"sap_fiori_3",
			"sap_horizon"
		]
	},
	"sap.ui5": {
		"resources": {
			"css": [
				{
					"uri": "css/style.css"
				}
			]
		},
		"rootView": {
			"viewName": "zgpms.meilpower.com.view.App",
			"type": "XML",
			"id": "app"
		},
		"dependencies": {
			"minUI5Version": "1.77.0",
			"libs": {
				"sap.m": {},
				"sap.tnt": {},
				"sap.ui.core": {},
				"sap.ui.layout": {},
				"sap.ui.unified": {},
				"sap.viz": {}
			}
		},
		"models": {
			"": {
				"dataSource": "mainService",
				"settings": {
					"useBatch": false
				}
			},
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleUrl": "i18n/i18n.properties",
					"async": true
				}
			}
		},
		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"controlId": "idMainApp",
				"viewType": "XML",
				"controlAggregation": "pages",
				"viewPath": "zgpms.meilpower.com.view"
			},
			"routes": [
				{
					"name": "home",
					"pattern": "",
					"target": "TargetHome"
				},
				{
					"name": "GatePassCreation",
					"pattern": "GatePassCreation/:type:",
					"target": "TargetGatePassCreation"
				},
				{
  "name": "GatePassList",
  "pattern": "GatePassList",
  "target": "TargetGatePassList"
},
				{
					"name": "OutGatePass",
					"pattern": "OutGatePass",
					"target": [
						"TargetOutGatePass"
					]
				},
				{
					"name": "reports",
					"pattern": "reports",
					"target": [
						"TargetReports"
					]
				},
				{
					"name": "InwardGatePass",
					"pattern": "InwardGatePass",
					"target": [
						"TargetInwardGatePass"
					]
				},
				{
					"name": "analytics",
					"pattern": "analytics",
					"target": ["TargetAnalytics"]
				}
			],
			"targets": {
				"TargetHome": {
					"viewName": "Home",
					"viewLevel": 1
				},
				"TargetGatePassCreation": {
					"viewName": "GatePassCreation",
					"viewLevel": 2
				},
				"TargetGatePassList": {
  "viewType": "XML",
  "viewId": "GatePassList",
  "viewName": "GatePassList"
},
				"TargetOutGatePass": {
					"viewType": "XML",
					"viewId": "OutGatePass",
					"viewName": "OutGatePass"
				},
				"TargetReports": {
					"viewType": "XML",
					"viewId": "Reports",
					"viewName": "Reports"
				},
				"TargetInwardGatePass": {
					"viewType": "XML",
					"viewId": "InwardGatePass",
					"viewName": "InwardGatePass"
				},
				"TargetAnalytics": {
					"viewType": "XML",
					"viewId": "Analytics",
					"viewName": "Analytics"
				}
			}
		}
	}
}
