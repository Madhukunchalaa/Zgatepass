{
	"_version": "1.21.0",
	"sap.app": {
		"id": "zgpms.meilpower.com",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"fallbackLocale": "en",
			"supportedLocales": ["en", "de"]
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"applicationVersion": {
			"version": "1.0.0"
		},
		"dataSources": {
			"mainService": {
				"uri": "/sap/opu/odata/sap/ZSEPC_GATEPASS_SRV/",
				"type": "OData",
				"settings": {
					"odataVersion": "2.0"
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		},
		"supportedThemes": [
			"sap_hcb",
			"sap_bluecrystal",
			"sap_fiori_3",
			"sap_horizon"
		]
	},
	"sap.ui5": {
		"resources": {
			"css": [
				{
					"uri": "css/style.css"
				}
			]
		},
		"rootView": {
			"viewName": "zgpms.meilpower.com.view.App",
			"type": "XML",
			"id": "app"
		},
		"dependencies": {
			"minUI5Version": "1.77.0",
			"libs": {
				"sap.m": {},
				"sap.tnt": {},
				"sap.ui.core": {},
				"sap.ui.layout": {}
			}
		},
		"models": {
			"": {
				"dataSource": "mainService",
				"settings": {
					"useBatch": false
				}
			},
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleUrl": "i18n/i18n.properties",
					"async": true
				}
			},
			"side": {
				"type": "sap.ui.model.json.JSONModel",
				"uri": "model/sideContent.json"
			}
		},
		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"controlId": "mainContents",
				"viewType": "XML",
				"controlAggregation": "pages",
				"viewPath": "zgpms.meilpower.com.view"
			},
			"routes": [
				{
					"pattern": "",
					"name": "home",
					"target": "home"
				},
				{
					"pattern": "GatePassRequestNumber",
					"name": "GatePassRequestNumber",
					"target": "GatePassRequestNumber"
				},
				{
					"pattern": "GatePassRequestCreation/:reqNo:/:plant:/:category:/:type:",
					"name": "GatePassRequestCreation",
					"target": "GatePassRequestCreation"
				},
				{
					"pattern": "OutGatePass",
					"name": "OutGatePass",
					"target": "OutGatePass"
				},
				{
					"pattern": "Gatepasslist",
					"name": "Gatepasslist",
					"target": "Gatepasslist"
				},
				{
					"pattern": "OutGatePassDetail/:reqNo:",
					"name": "OutGatePassDetail",
					"target": "OutGatePassDetail"
				},
				{
					"pattern": "GatePassExit",
					"name": "GatePassExit",
					"target": "GatePassExit"
				},
				{
					"pattern": "GatePassExitDetail/:reqNo:",
					"name": "GatePassExitDetail",
					"target": "GatePassExitDetail"
				},
				{
					"pattern": "GatePassReturn",
					"name": "GatePassReturn",
					"target": "GatePassReturn"
				},
				{
					"pattern": "GatePassReturnDetail/:reqNo:",
					"name": "GatePassReturnDetail",
					"target": "GatePassReturnDetail"
				},
				{
					"pattern": "ReceiptGatePass",
					"name": "ReceiptGatePass",
					"target": "ReceiptGatePass"
				}
			],
			"targets": {
				"home": {
					"viewId": "home",
					"viewName": "Home"
				},
				"GatePassRequestNumber": {
					"viewId": "GatePassRequestNumber",
					"viewName": "GatePassRequestNumber"
				},
				"GatePassRequestCreation": {
					"viewId": "GatePassRequestCreation",
					"viewName": "GatePassRequestCreation"
				},
				"OutGatePass": {
					"viewId": "OutGatePass",
					"viewName": "OutGatePass"
				},
				"OutGatePassDetail": {
					"viewId": "OutGatePassDetail",
					"viewName": "OutGatePassDetail"
				},
				"Gatepasslist": {
					"viewId": "Gatepasslist",
					"viewName": "Gatepasslist"
				},
				"GatePassExit": {
					"viewId": "GatePassExit",
					"viewName": "GatePassExit"
				},
				"GatePassExitDetail": {
					"viewId": "GatePassExitDetail",
					"viewName": "GatePassExitDetail"
				},
				"GatePassReturn": {
					"viewId": "GatePassReturn",
					"viewName": "GatePassReturn"
				},
				"GatePassReturnDetail": {
					"viewId": "GatePassReturnDetail",
					"viewName": "GatePassReturnDetail"
				},
				"ReceiptGatePass": {
					"viewId": "ReceiptGatePass",
					"viewName": "ReceiptGatePass"
				}
			}
		}
	}
}