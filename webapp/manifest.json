{
	"_version": "1.21.0",
	"sap.app": {
		"id": "zgpms.meilpower.com",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"fallbackLocale": "en",
			"supportedLocales": ["en", "de"],
			"terminologies": {
				"sports": {
					"bundleUrl": "i18n/terminologies/sports/i18n.terminologies.sports.properties",
					"bundleUrlRelativeTo": "manifest",
					"supportedLocales": ["en", "de"]
				},
				"travel": {
					"bundleUrl": "i18n/terminologies/travel/i18n.terminologies.travel.properties",
					"bundleUrlRelativeTo": "manifest",
					"supportedLocales": ["en", "de"]
				}
			}
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"applicationVersion": {
			"version": "1.0.0"
		},
		"dataSources": {
			"mainService": {
				"uri": "/sap/opu/odata/sap/ZSEPC_GATEPASS_SRV/",
				"type": "OData",
				"settings": {
					"odataVersion": "2.0"
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		},
		"supportedThemes": [
			"sap_hcb",
			"sap_bluecrystal",
			"sap_fiori_3",
			"sap_horizon"
		]
	},
	"sap.ui5": {
		   "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ],
            "js": []
        },

		"rootView": {
			"viewName": "zgpms.meilpower.com.view.App",
			"type": "XML",
			"id": "app"
		},
	
		"dependencies": {
			"minUI5Version": "1.77.0",
			"libs": {
				"sap.m": {},
				"sap.suite.ui.microchart": {
					"lazy": true
				},
				"sap.tnt": {},
				"sap.ui.core": {},
				"sap.ui.layout": {},
				"sap.uxap": {}
			}
		},
		"models": {
			"": {
				"dataSource": "mainService",
				"settings": {
					"useBatch": false
				}
			},
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleUrl": "i18n/i18n.properties",
					"async": true,
					"fallbackLocale": "en",
					"supportedLocales": ["en", "de"],
					"terminologies": {
						"sports": {
							"bundleUrl": "i18n/terminologies/sports/i18n.terminologies.sports.properties",
							"bundleUrlRelativeTo": "manifest",
							"supportedLocales": ["en", "de"]
						},
						"travel": {
							"bundleUrl": "i18n/terminologies/travel/i18n.terminologies.travel.properties",
							"bundleUrlRelativeTo": "manifest",
							"supportedLocales": ["en", "de"]
						}
					},
					"enhanceWith": [
						{
							"bundleUrl": "reuse/appvar1/i18n/i18n.properties",
							"fallbackLocale": "en",
							"supportedLocales": [
								"en", "de"
							],
							"terminologies": {
								"sports": {
									"bundleUrl": "reuse/appvar1/i18n/terminologies/sports/i18n.terminologies.sports.properties",
									"bundleUrlRelativeTo": "manifest",
									"supportedLocales": [
										"en", "de"
									]
								},
								"travel": {
									"bundleUrl": "reuse/appvar1/i18n/terminologies/travel/i18n.terminologies.travel.properties",
									"bundleUrlRelativeTo": "manifest",
									"supportedLocales": [
										"en", "de"
									]
								}
							}
						},
						{
							"bundleUrl": "reuse/appvar2/i18n/i18n.properties",
							"bundleUrlRelativeTo": "manifest",
							"supportedLocales": [
								"en",
								"de"
							],
							"fallbackLocale": "en",
							"terminologies": {
								"travel": {
									"bundleUrl": "reuse/appvar2/i18n/terminologies/travel/i18n.terminologies.travel.properties",
									"bundleUrlRelativeTo": "manifest",
									"supportedLocales": [
										"en", "de"
									]
								}
							}
						}
					]
				}
			},
			"side": {
				"type": "sap.ui.model.json.JSONModel",
				"uri": "model/sideContent.json"
			},
			"alerts": {
				"type": "sap.ui.model.json.JSONModel",
				"uri": "model/alerts.json"
			},
			"customer": {
				"type": "sap.ui.model.json.JSONModel",
				"uri": "model/customers.json"
			}
		},
		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"controlId": "mainContents",
				"viewType": "XML",
				"controlAggregation": "pages",
				"viewPath": "zgpms.meilpower.com.view"
			},
			"routes": [
				{
					"pattern": "",
					"name": "home",
					"target": "home"
				},
				{
					"pattern": "Reports",
					"name": "Reports",
					"target": "Reports"
				},
				{
					"pattern": "MasterSettings",
					"name": "masterSettings",
					"target": [
						"detailSettings",
						"masterSettings"
					]
				},
				{
					"pattern": "MasterSettings/SystemSettings",
					"name": "systemSettings",
					"target": [
						"detailSettings",
						"masterSettings"
					]
				},
				{
					"pattern": "Statistics",
					"name": "statistics",
					"target": "statistics"
				},
				{
					"pattern": "GatepassList",
					"name": "GatepassList",
					"target": "GatepassList"
				},
				{
					"pattern": "OrderStatistics",
					"name": "orderStatistics",
					"target": "orderStatistics"
				},
				{
					"pattern": "Editgatepass",
					"name": "Editgatepass",
					"target": "Editgatepass"
				},
					{
					"pattern": "Creategatepass",
					"name": "Creategatepass",
					"target": "Creategatepass"
				},
				{
					"pattern": "GatePassRequestCreation",
					"name": "GatePassRequestCreation",
					"target": "GatePassRequestCreation"
				},
				{
					"pattern": "GatePassCreation/:reqNo:",
					"name": "GatePassCreation",
					"target": "GatePassCreation"
				},
				{
					"pattern": "ImportantLinks",
					"name": "importantLinks",
					"target": "importantLinks"
				},
				{
					"pattern": "Legal",
					"name": "legal",
					"target": "legal"
				}
			],
			"targets": {
				"home": {
					"viewId": "home",
					"viewName": "Home"
				},
				"Reports": {
					"viewId": "Reports",
					"viewName": "Reports"
				},
				"appSettings": {
					"viewId": "appSettings",
					"viewName": "settings.AppSettings"
				},
				"masterSettings": {
					"viewId": "masterSettings",
					"viewName": "settings.MasterSettings",
					"controlId": "appSettings",
					"controlAggregation": "masterPages",
					"parent": "appSettings"
				},
				"detailSettings": {
					"viewId": "detailSettings",
					"viewName": "settings.DetailSettings",
					"controlId": "appSettings",
					"controlAggregation": "detailPages",
					"parent": "appSettings"
				},
				"statistics": {
					"viewId": "statistics",
					"viewName": "Statistics"
				},
				"GatepassList": {
					"viewId": "GatepassList",
					"viewName": "GatepassList"
				},
				"orderStatistics": {
					"viewId": "orderStatistics",
					"viewName": "OrderStatistics"
				},
					"Creategatepass": {
					"viewId": "Creategatepass",
					"viewName": "Creategatepass"
				},
				"GatePassRequestCreation": {
					"viewId": "GatePassRequestCreation",
					"viewName": "GatePassRequestCreation"
				},
				"GatePassCreation": {
					"viewId": "GatePassCreation",
					"viewName": "GatePassCreation"
				},
					"Editgatepass": {
					"viewId": "Editgatepass",
					"viewName": "Editgatepass"
				},
				"importantLinks": {
					"viewId": "importantLinks",
					"viewName": "ImportantLinks"
				},
				"legal": {
					"viewId": "legal",
					"viewName": "Legal"
				}
			}
		}
	}
}